# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo

# Node / build artifacts (por si alguien corre los proyectos de kb/references/)
node_modules/
.next/
dist/
build/
.astro/
.cache/
.parcel-cache/
*.tsbuildinfo

# Env / secrets — NUNCA commitearlos
.env
.env.local
.env.*.local
*.env

# Claude Code local settings (personales por usuario, no del proyecto)
.claude/settings.local.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# DBs locales
*.db
*.sqlite
*.sqlite3
.data/

# Output del pipeline — datos de clientes, no van al template
plugins/agente-pagina-web/output/*/
!plugins/agente-pagina-web/output/.gitkeep

# Briefs de clientes reales — NO commitear datos de clientes al template público
plugins/agente-pagina-web/briefs/*/
!plugins/agente-pagina-web/briefs/_template/
!plugins/agente-pagina-web/briefs/.gitkeep

# Zips y binarios pesados ocasionales
*.zip
*.tar.gz
