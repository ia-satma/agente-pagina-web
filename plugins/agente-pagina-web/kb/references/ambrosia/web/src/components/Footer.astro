---
import { t, pathFor, type Locale } from '~/i18n';
import Logo from '~/components/Logo.astro';
import FloralRule from '~/components/FloralRule.astro';
import Phonetic from '~/components/Phonetic.astro';
import { getSocialLinks, isVisible, type SocialPlatform } from '~/lib/settings';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const year = new Date().getFullYear();

/* Redes sociales — leidas desde el backend (settings.social.<platform>).
   Si no hay URL configurada, no se renderiza el icono.
   Email tiene un fallback default a concierge@ambrosiasauceofgods.com */
const socialLinks = getSocialLinks();
const isES = locale === 'es';
const showNewsletter = isVisible('footer.newsletter');
---

<footer class="footer">
  <FloralRule variant="mini" tone="ink" class="footer__floral" />

  <div class="footer__inner">
    <div class="footer__brand">
      <Logo variant="lockup" size="md" tone="white" />
      <p class="footer__phon"><Phonetic tone="auto" /></p>
      <p class="footer__tagline font-script">{dict.footer.tagline}</p>
    </div>

    <nav class="footer__nav" aria-label="footer">
      <ul>
        <li><a class="link-rule" href={pathFor(locale, 'origen')}>{(dict.nav as any).origen}</a></li>
        <li><a class="link-rule" href={pathFor(locale, 'la-salsa')}>{(dict.nav as any)['la-salsa']}</a></li>
        <li><a class="link-rule" href={pathFor(locale, 'recetario')}>{(dict.nav as any).recetario}</a></li>
        <li><a class="link-rule" href={pathFor(locale, 'mesas')}>{(dict.nav as any).mesas}</a></li>
        <li><a class="link-rule" href={pathFor(locale, 'concierge')}>{(dict.nav as any).concierge}</a></li>
      </ul>
    </nav>

    <div class="footer__news">
      {showNewsletter && (
        <form onsubmit="return false;">
          <p class="eyebrow">{dict.footer.newsletter.title}</p>
          <label class="footer__news-row">
            <input type="email" required placeholder={dict.footer.newsletter.placeholder} />
            <button type="submit" class="footer__news-submit" aria-label={dict.footer.newsletter.cta}>
              <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M0 5h13M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </label>
        </form>
      )}

      {socialLinks.length > 0 && (
        <ul class="footer__social" aria-label={isES ? 'Redes sociales' : 'Social media'}>
          {socialLinks.map((link) => (
            <li>
              <a
                class="footer__social-link"
                href={link.url}
                aria-label={link.label}
                target={link.url.startsWith('mailto:') ? undefined : '_blank'}
                rel={link.url.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
              >
                {link.platform === 'instagram' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.5" />
                    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5" />
                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
                  </svg>
                )}
                {link.platform === 'facebook' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M15 3h-3a4 4 0 0 0-4 4v3H5v4h3v7h4v-7h3l1-4h-4V7a1 1 0 0 1 1-1h3V3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                  </svg>
                )}
                {link.platform === 'twitter' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 4l16 16M20 4L4 20" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                  </svg>
                )}
                {link.platform === 'tiktok' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M14 4v10.5a3.5 3.5 0 1 1-3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none" />
                    <path d="M14 4c0 2.5 2 4.5 4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                )}
                {link.platform === 'youtube' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="3" y="6" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.5" />
                    <path d="M10 9.5L14.5 12L10 14.5z" fill="currentColor" />
                  </svg>
                )}
                {link.platform === 'email' && (
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <rect x="3" y="5" width="18" height="14" rx="1" stroke="currentColor" stroke-width="1.5" />
                    <path d="M3 7L12 13L21 7" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-left">
      <span>© {year} AMBROSIA</span>
      <span class="footer__sep">·</span>
      <span>{dict.footer.made_in}</span>
    </div>

    <div class="footer__bottom-right">
      <a class="footer__credit" href="https://satma.mx" target="_blank" rel="noopener noreferrer" aria-label="SATMA · satma.mx">
        <span>{isES ? 'Por' : 'By'}</span>
        <span class="footer__credit-name">SATMA</span>
        <svg width="9" height="9" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>

      <a class="footer__admin" href="/admin/index.html" rel="nofollow noopener" aria-label="Backend" title="Backend">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 7a4 4 0 1 1-3.5 5.96L6 18.5l-1.5-1.5L11.04 10.5A4 4 0 0 1 15 7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
          <circle cx="15" cy="11" r="1.2" fill="currentColor" />
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-purple-block);
    color: var(--text-on-color);
    padding: 0 1.5rem 1rem;
    position: relative;
  }

  .footer :global(.footer__floral) {
    margin: 0 auto;
    padding: 1rem 0 0.85rem;
    max-width: 360px;
    opacity: 0.5;
  }

  /* ─── Inner: 3 cols editorial compacto ─── */
  .footer__inner {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1.2fr;
    gap: 2rem;
    padding: 1rem 0 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent);
  }

  .footer__brand p { margin: 0; }
  .footer__phon {
    margin-top: 0.4rem !important;
    font-size: 0.6rem;
    letter-spacing: var(--tracking-eyebrow);
    opacity: 0.45;
  }
  .footer__tagline {
    margin-top: 0.65rem !important;
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    opacity: 0.7;
  }

  /* ─── Nav ─── */
  .footer__nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.35rem;
  }
  .footer__nav a {
    color: var(--color-white);
    text-decoration: none;
    font-size: 0.66rem;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    opacity: 0.65;
    transition: opacity var(--dur-fast) var(--ease-fast);
  }
  .footer__nav a:hover { opacity: 1; }

  /* ─── Newsletter ─── */
  .footer__news .eyebrow {
    color: var(--color-white);
    opacity: 0.55;
    margin: 0 0 0.55rem;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
  }
  .footer__news-row {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-white) 24%, transparent);
    padding-bottom: 0.4rem;
    max-width: 22rem;
    transition: border-color var(--dur-medium) var(--ease-medium);
  }
  .footer__news-row:focus-within {
    border-bottom-color: color-mix(in srgb, var(--color-white) 55%, transparent);
  }
  .footer__news-row input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: 0.8rem;
    padding: 0.25rem 0;
    outline: none;
  }
  .footer__news-row input::placeholder {
    color: color-mix(in srgb, var(--color-white) 40%, transparent);
  }
  .footer__news-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    color: var(--color-white);
    cursor: pointer;
    padding: 0 0.2rem;
    opacity: 0.75;
    transition:
      opacity var(--dur-fast) var(--ease-fast),
      transform var(--dur-medium) var(--ease-medium);
  }
  .footer__news-submit:hover {
    opacity: 1;
    transform: translateX(3px);
  }

  /* ─── Redes sociales: minimalista, 28px sin pill ─── */
  .footer__social {
    list-style: none;
    margin: 1.15rem 0 0;
    padding: 0;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }
  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: var(--color-white);
    text-decoration: none;
    opacity: 0.55;
    transition:
      opacity var(--dur-medium) var(--ease-medium),
      color var(--dur-medium) var(--ease-medium),
      transform var(--dur-medium) var(--ease-medium);
  }
  .footer__social-link:hover {
    opacity: 1;
    color: var(--color-red);
    transform: translateY(-2px);
  }
  .footer__social-link svg { display: block; }

  /* ─── Bottom bar: 2 columnas ultra minimal ─── */
  .footer__bottom {
    max-width: 1180px;
    margin: 0.85rem auto 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .footer__bottom-left,
  .footer__bottom-right {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: color-mix(in srgb, var(--color-white) 55%, transparent);
  }
  .footer__sep { opacity: 0.4; }

  /* Credit SATMA — link minimal */
  .footer__credit {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: color-mix(in srgb, var(--color-white) 60%, transparent);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 500;
    letter-spacing: 0.22em;
    transition: color var(--dur-medium) var(--ease-medium);
  }
  .footer__credit-name {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--color-white);
  }
  .footer__credit svg {
    transition: transform var(--dur-medium) var(--ease-medium);
    opacity: 0.7;
  }
  .footer__credit:hover {
    color: var(--color-white);
  }
  .footer__credit:hover svg {
    transform: translate(2px, -2px);
    opacity: 1;
  }

  /* Admin link minimal */
  .footer__admin {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: color-mix(in srgb, var(--color-white) 45%, transparent);
    text-decoration: none;
    transition:
      color var(--dur-medium) var(--ease-medium),
      transform var(--dur-medium) var(--ease-medium);
  }
  .footer__admin svg {
    display: block;
    transform: rotate(-45deg);
  }
  .footer__admin:hover {
    color: var(--color-red);
    transform: translateY(-1px);
  }

  @media (max-width: 860px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.65rem;
    }
  }
</style>
