---
/**
 * RecipeIntro — header del detalle de receta (imagen hero + titulo + categoria).
 */
import { CATEGORIAS, type Receta } from '~/data/recetas';
import { pathFor, type Locale } from '~/i18n';

interface Props {
  receta: Receta;
  locale: Locale;
}

const { receta, locale } = Astro.props;
const cat = CATEGORIAS.find((c) => c.key === receta.categoria);
const catLabel = cat ? (locale === 'es' ? cat.label_es : cat.label_en) : '';
const backLabel = locale === 'es' ? '← Recetario' : '← Recipe Book';
const backHref = pathFor(locale, 'recetario');

// Hero variant (1600x1000) en lugar de la card cuadrada (800x800).
const heroImg = receta.imagen.replace(/\.webp$/, '-hero.webp');
---

<section class="recipe-intro">
  <div class="recipe-intro__inner">
    <a class="recipe-intro__back link-rule" href={backHref}>{backLabel}</a>

    <p class="recipe-intro__num">{receta.numero}</p>
    <p class="recipe-intro__cat">{catLabel}</p>
    <h1 class="recipe-intro__title">{receta.titulo}</h1>

    <figure class="recipe-intro__figure">
      <img
        src={heroImg}
        alt={receta.titulo}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1600"
        height="1000"
      />
    </figure>
  </div>
</section>

<style>
  .recipe-intro {
    background: var(--bg-page);
    color: var(--navy);
    padding: clamp(3.5rem, 7vw, 5rem) 1.5rem clamp(2rem, 4vw, 3rem);
  }
  .recipe-intro__inner {
    max-width: 1080px;
    margin: 0 auto;
    text-align: center;
  }

  .recipe-intro__back {
    display: inline-block;
    margin: 0 0 2.5rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--navy);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity var(--dur-fast) var(--ease-fast);
  }
  .recipe-intro__back:hover { opacity: 1; }

  .recipe-intro__num {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    color: var(--red);
  }
  .recipe-intro__cat {
    margin: 0 0 1.25rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--navy);
    opacity: 0.55;
  }
  .recipe-intro__title {
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: 0.01em;
    color: var(--navy);
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
  }

  .recipe-intro__figure {
    margin: 0;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border-radius: 4px;
    background: color-mix(in srgb, var(--navy) 6%, var(--cream));
  }
  .recipe-intro__figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
