---
import { t, type Locale } from '~/i18n';
import Seal from '~/components/Seal.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section id="ritual" class="ritual">
  <figure class="ritual__figure cursor-target">
    <img
      src="/images/ritual-guardianes.webp"
      alt="Pintura barroca novohispana: tres guardianes indigenas de la receta de AMBROSIA — joven artesano ofreciendo la botella, elder con molcajete, anciano con baculo, escuela de Juan Correa"
      loading="eager"
      decoding="async"
      class="ritual__img"
    />
    <span class="bracket bracket--tl" aria-hidden="true"></span>
    <span class="bracket bracket--tr" aria-hidden="true"></span>
    <span class="bracket bracket--bl" aria-hidden="true"></span>
    <span class="bracket bracket--br" aria-hidden="true"></span>
  </figure>

  <div class="ritual__text">
    <p class="eyebrow" data-reveal>{dict.ritual.eyebrow}</p>
    <h2 class="ritual__title title-skew" data-reveal set:html={dict.ritual.title}></h2>
    <p class="ritual__body" data-reveal set:html={dict.ritual.body}></p>

    <div class="ritual__signature" data-reveal aria-hidden="true">
      <Seal variant="purple" size="md" />
    </div>
  </div>
</section>

<style>
  .ritual {
    position: relative;
    padding: clamp(3.5rem, 7vw, 6rem) 1.5rem clamp(3.5rem, 8vw, 7rem);
    background: var(--bg-page);
    color: var(--navy);
  }

  .ritual__figure {
    position: relative;
    margin: 0 auto;
    max-width: 1180px;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-xl);
  }
  @media (max-width: 768px) {
    .ritual__figure { border-radius: var(--radius-lg); }
  }
  .ritual__figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    transform-origin: 50% 50%;
    transition: transform var(--dur-divine) var(--ease-divine);
  }
  /* Imagen siempre visible — sin fade-in que cree pop-in.
     La ritual-guardianes.webp esta preloaded en Base.astro para /origen,
     asi que se renderiza instantaneamente. Kenburns arranca de inmediato. */
  .ritual__img {
    opacity: 1;
    filter: saturate(0.92);
    transform: scale(1);
    animation: ritual-kenburns 18s ease-in-out infinite;
    transition: transform var(--dur-divine) var(--ease-divine);
  }
  .ritual__figure:hover img {
    animation-play-state: paused;
    transform: scale(1.05);
  }
  @keyframes ritual-kenburns {
    0%   { transform: scale(1.0)  translate(0, 0); }
    50%  { transform: scale(1.05) translate(1%, -0.5%); }
    100% { transform: scale(1.0)  translate(0, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ritual__figure img { animation: none; }
  }

  /* Brackets de hover */
  .bracket {
    position: absolute; width: 18px; height: 18px;
    border-color: var(--navy);
    border-style: solid; border-width: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-medium) var(--ease-medium),
                top var(--dur-medium) var(--ease-medium),
                left var(--dur-medium) var(--ease-medium),
                right var(--dur-medium) var(--ease-medium),
                bottom var(--dur-medium) var(--ease-medium);
  }
  .bracket--tl { top: 14px; left: 14px;   border-top-width: 1px; border-left-width: 1px; }
  .bracket--tr { top: 14px; right: 14px;  border-top-width: 1px; border-right-width: 1px; }
  .bracket--bl { bottom: 14px; left: 14px;  border-bottom-width: 1px; border-left-width: 1px; }
  .bracket--br { bottom: 14px; right: 14px; border-bottom-width: 1px; border-right-width: 1px; }
  .ritual__figure:hover .bracket { opacity: 0.9; }
  .ritual__figure:hover .bracket--tl { top: 8px; left: 8px; }
  .ritual__figure:hover .bracket--tr { top: 8px; right: 8px; }
  .ritual__figure:hover .bracket--bl { bottom: 8px; left: 8px; }
  .ritual__figure:hover .bracket--br { bottom: 8px; right: 8px; }

  .ritual__text {
    text-align: center;
    max-width: 38rem;
    margin: 2rem auto 0;
  }
  .ritual__text .eyebrow {
    margin: 0 0 0.85rem;
    color: var(--page-accent, var(--navy));
    opacity: 0.55;
  }
  .ritual__title {
    margin: 0 0 0.85rem;
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
    font-size: clamp(1.85rem, 3.6vw, 2.8rem);
    line-height: 1.25;
    color: var(--navy);
  }
  .ritual__body {
    margin: 0;
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: 1.65;
    color: var(--navy);
    opacity: 0.78;
  }

  .ritual__signature {
    margin-top: 1.5rem;
    display: inline-flex;
    justify-content: center;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity var(--dur-divine) var(--ease-divine), transform var(--dur-divine) var(--ease-divine);
  }
  [data-reveal].is-in {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const els = document.querySelectorAll<HTMLElement>('.ritual [data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target as HTMLElement;
          const siblings = Array.from(target.parentElement?.querySelectorAll<HTMLElement>('[data-reveal]') ?? []);
          const idx = siblings.indexOf(target);
          setTimeout(() => target.classList.add('is-in'), idx * 85);
          io.unobserve(target);
        }
      });
    }, { threshold: 0.2 });
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => el.classList.add('is-in'));
  }
</script>
