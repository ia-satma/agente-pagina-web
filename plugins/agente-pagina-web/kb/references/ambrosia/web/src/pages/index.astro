---
export const prerender = true;
/**
 * Home — Minimalista editorial.
 *
 * Estructura:
 *   01 Hero          → HeroVideo autoplay loop
 *   02 Claim         → BrandStatement (AMBROSIA + tagline + CTA)
 *   03 Manifesto     → "THE DIVINE SAUCE OF GODS" + isotipo
 *   04 Timeline      → TimelineCultural (4 hitos: mito → AMBROSIA hoy) — cierre historico
 *   05 Footer
 *
 * Navegacion a los 5 mundos: en el Nav superior (no duplicar grid en home).
 */
import Base from '~/layouts/Base.astro';
import HeroVideo from '~/components/HeroVideo.astro';
import BrandStatement from '~/components/BrandStatement.astro';
import VideoReel from '~/components/VideoReel.astro';
import WorldsGrid from '~/components/WorldsGrid.astro';
import Manifesto from '~/components/Manifesto.astro';
import BottleGallery from '~/components/BottleGallery.astro';
import MotionDivider from '~/components/MotionDivider.astro';
import Footer from '~/components/Footer.astro';
import SEOSchema from '~/components/SEOSchema.astro';
import { isVisible } from '~/lib/settings';

const locale = 'es' as const;
---

<Base
  title="AMBROSIA — La salsa divina de los dioses"
  locale={locale}
  description="Salsa picante mexicana ultra-lujo embotellada a mano en Monterrey. Inspirada en el elixir de los dioses del Olimpo. Una sola gota basta para transformar un plato."
>
  <SEOSchema type="home" locale={locale} />
  {isVisible('home.hero') && <HeroVideo locale={locale} />}

  {isVisible('home.brandStatement') && <BrandStatement locale={locale} />}

  {/* ─── Video reel 1080p — tres momentos del ritual de AMBROSIA.
      Captions basados en la narrativa: ritual de conexion, alquimia
      del frasco, encuentro alrededor del fuego. */}
  <VideoReel
    eyebrow="El ritual"
    title='AMBROSIA no es solo una salsa'
    body="Es un ritual de conexion, un fragmento del tiempo, un eco de los cantos antiguos. Tres momentos capturados en 1080p."
    videos={[
      {
        src: '/video/reel-01.webm',
        srcMp4: '/video/reel-01.mp4',
        poster: '/video/reel-01-poster.jpg',
        caption: 'El ritual — cada gota es el espiritu de la abundancia y la tradicion.',
      },
      {
        src: '/video/reel-02.webm',
        srcMp4: '/video/reel-02.mp4',
        poster: '/video/reel-02-poster.jpg',
        caption: 'El frasco del alquimista — oscuro, robusto, guardando un fragmento del tiempo.',
      },
      {
        src: '/video/reel-03.webm',
        srcMp4: '/video/reel-03.mp4',
        poster: '/video/reel-03-poster.jpg',
        caption: 'El encuentro — un viaje a los origenes, donde lo humano y lo divino se sentaban al fuego.',
      },
    ]}
  />

  {isVisible('home.worldsGrid') && <WorldsGrid locale={locale} />}

  <MotionDivider variant="ornament" />

  {isVisible('home.manifesto') && <Manifesto locale={locale} />}

  <MotionDivider variant="drop" />

  {isVisible('home.bottleGallery') && <BottleGallery locale={locale} />}

  <Footer locale={locale} />
</Base>
