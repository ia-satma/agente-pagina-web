# ───────────────────────────────────────────────────────────────────
# Ambrosía CMS — Plantilla de variables de entorno
# COPIA este archivo como .env (local) o pega los valores en Replit Secrets.
# NUNCA commitees el .env real (está en .gitignore).
# ───────────────────────────────────────────────────────────────────

# Email del único usuario admin
AUTH_USER=ia@satma.mx

# Hash bcrypt de la contraseña (BASE64 — evita conflictos con dotenv expansion).
# Generar con: pnpm run gen-hash "tuPasswordAqui"
# El script imprime el valor base64 listo para pegar acá.
AUTH_PASS_HASH_B64=

# Alternativa raw (solo si tu host NO expande $ — ej. Replit Secrets):
# AUTH_PASS_HASH=$2b$12$...

# Secret aleatorio para firmar cookies de sesión.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# (Variable DECAP_PROXY_PORT removida — el CMS es custom Astro
# en /admin/*, no Decap. Ver src/middleware.ts y src/pages/admin/)
