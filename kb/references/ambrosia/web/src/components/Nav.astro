---
import { otherLocale, pathFor, localizedHref, t, type Locale } from '~/i18n';
import Logo from '~/components/Logo.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const navDict = dict.nav as Record<string, string>;
const other = otherLocale(locale);
const langSwitchHref = localizedHref(locale, Astro.url.pathname, other);
const currentPath = Astro.url.pathname;

// 5 mundos canonicos (reestructura Clase Azul)
const mundos = [
  { slug: 'origen',    n: '01' },
  { slug: 'la-salsa',  n: '02' },
  { slug: 'recetario', n: '03' },
  { slug: 'mesas',     n: '04' },
  { slug: 'concierge', n: '05' },
] as const;
---

<nav class="nav" data-nav>
  <div class="nav__inner">
    <a class="nav__brand" href={pathFor(locale)} aria-label="AMBROSIA — Inicio">
      <Logo variant="wordmark" size="md" tone="ink" />
    </a>

    <ul class="nav__links" aria-label={locale === 'es' ? 'Navegacion principal' : 'Main navigation'}>
      {mundos.map(({ slug, n }) => {
        const href = pathFor(locale, slug);
        const isActive = currentPath === href || currentPath.startsWith(href + '/');
        const label = navDict[slug];
        return (
          <li class="nav__link-item">
            <a
              class="nav__link"
              href={href}
              aria-current={isActive ? 'page' : undefined}
            >
              <span class="nav__num" aria-hidden="true">{n}</span>
              <span class="nav__label">{label}</span>
            </a>
          </li>
        );
      })}
    </ul>

    <div class="nav__meta">
      <a class="nav__lang" href={langSwitchHref} aria-label={`Cambiar idioma a ${other}`}>
        {locale === 'es' ? 'EN' : 'ES'}
      </a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--bg-page);
    border-bottom: 1px solid var(--line-soft);
    transition: background-color var(--dur-medium) var(--ease-medium);
    /* Safe-area-inset-top: respeta el notch de iPhone (Dynamic Island,
       sensores) y el status bar de Android para no quedar oculto bajo
       ellos. Suma al padding interior del nav__inner. */
    padding-top: env(safe-area-inset-top, 0);
  }
  .nav[data-scrolled="true"] {
    background: color-mix(in srgb, var(--bg-page) 92%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .nav__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0.55rem 1.5rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    min-height: 56px;
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--navy);
    justify-self: start;
    overflow: hidden;
    height: 36px;
    transition: opacity var(--dur-fast) var(--ease-fast);
  }
  .nav__brand:hover { opacity: 0.85; }

  /* Links centrales — editorial con numeracion */
  .nav__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.6rem, 1.4vw, 1.5rem);
    justify-self: center;
  }
  .nav__link-item { line-height: 1; }
  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    padding: 0.5rem 0.6rem;
    color: var(--navy);
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    /* opacity: 0.55 daba ratio 3.92:1 sobre blanco (bajo WCAG AA 4.5).
       0.72 da ratio 4.6:1 — pasa AA manteniendo la sensación atenuada. */
    opacity: 0.72;
    border-radius: 4px;
    transition: opacity var(--dur-fast) var(--ease-fast),
                background-color var(--dur-fast) var(--ease-fast),
                transform var(--dur-fast) var(--ease-fast);
  }
  .nav__num {
    font-family: var(--font-display, var(--font-body));
    font-weight: 400;
    font-size: 0.62rem;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }
  .nav__label { display: inline-block; }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0.6rem; right: 0.6rem;
    bottom: 0.25rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--dur-medium) var(--ease-medium);
  }
  .nav__link:hover {
    opacity: 1;
    background: color-mix(in srgb, var(--navy) 7%, transparent);
    transform: translateY(-1px);
  }
  .nav__link:hover::after,
  .nav__link[aria-current="page"]::after { transform: scaleX(1); }
  .nav__link[aria-current="page"] { opacity: 1; }
  .nav__link:focus-visible {
    outline: 1px solid var(--navy);
    outline-offset: 2px;
  }

  .nav__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: end;
  }

  .nav__lang {
    padding: 0.45rem 0.7rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--navy);
    /* opacity 0.55 → 0.72 para WCAG AA (4.6:1 vs 3.92:1 anterior) */
    opacity: 0.72;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--navy) 22%, transparent);
    transition: opacity var(--dur-fast) var(--ease-fast),
                border-color var(--dur-fast) var(--ease-fast),
                background-color var(--dur-fast) var(--ease-fast);
  }
  .nav__lang:hover {
    opacity: 1;
    border-color: var(--navy);
    background: color-mix(in srgb, var(--navy) 7%, transparent);
  }

  /* Mobile: links bajo el logo en una segunda fila scrollable */
  @media (max-width: 920px) {
    .nav__inner {
      padding: 0.85rem 1.25rem;
      gap: 0.75rem;
      grid-template-columns: auto 1fr auto;
      grid-template-rows: auto auto;
    }
    .nav__brand { grid-row: 1; grid-column: 1; }
    .nav__meta  { grid-row: 1; grid-column: 3; }
    .nav__links {
      grid-row: 2;
      grid-column: 1 / -1;
      justify-self: stretch;
      justify-content: flex-start;
      gap: 1rem;
      overflow-x: auto;
      padding: 0.4rem 0 0.1rem;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .nav__links::-webkit-scrollbar { display: none; }
    .nav__link { font-size: 0.62rem; white-space: nowrap; }
  }
</style>

<script>
  const navEl = document.querySelector<HTMLElement>('[data-nav]');

  // Crossfade del nav cuando scrollY > 120px — translucent + blur
  if (navEl) {
    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          navEl.dataset.scrolled = window.scrollY > 120 ? 'true' : 'false';
          ticking = false;
        });
        ticking = true;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
