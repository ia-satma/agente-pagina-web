---
/**
 * RecipeTeaser — 3 recetas destacadas en home → CTA al recetario.
 * Cards con imagen, numero (numero del recetario), titulo, tiempo y rinde.
 * Hover: zoom suave a la imagen + flecha del card crece.
 */
import { pathFor, t, type Locale } from '~/i18n';
import { recetasDestacadas } from '~/data/recetas';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const r = (dict as any).recipeTeaser as {
  eyebrow: string;
  title: string;
  body: string;
  cta: string;
};

const featured = recetasDestacadas();
---

<section class="recipe-teaser" data-recipe-teaser>
  <div class="recipe-teaser__inner">
    <header class="recipe-teaser__header">
      <p class="eyebrow recipe-teaser__eyebrow" data-anim="up">{r.eyebrow}</p>
      <h2 class="recipe-teaser__title" data-anim="up" set:html={r.title}></h2>
      <p class="recipe-teaser__body" data-anim="up">{r.body}</p>
    </header>

    <ul class="recipe-teaser__list" role="list">
      {featured.map((rec, i) => (
        <li class="recipe-teaser__item" data-anim="up" style={`--i:${i}`}>
          <a class="recipe-card" href={pathFor(locale, `recetario/${rec.slug}`)}>
            <figure class="recipe-card__figure">
              <img
                src={rec.imagen}
                alt={rec.titulo}
                loading="lazy"
                decoding="async"
                width="600"
                height="600"
              />
            </figure>
            <div class="recipe-card__body">
              <span class="recipe-card__num" aria-hidden="true">{rec.numero}</span>
              <h3 class="recipe-card__title">{rec.titulo}</h3>
              <p class="recipe-card__meta">
                <span>{rec.tiempo}</span>
                <span aria-hidden="true">·</span>
                <span>{rec.rinde}</span>
              </p>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <div class="recipe-teaser__cta" data-anim="up">
      <a class="btn btn--primary btn--lg" href={pathFor(locale, 'recetario')}>
        <span>{r.cta}</span>
        <span aria-hidden="true">
          <svg width="16" height="11" viewBox="0 0 14 10" fill="none">
            <path d="M0 5h13M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .recipe-teaser {
    background: var(--bg-page);
    color: var(--navy);
    padding: clamp(3rem, 6vw, 5rem) 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--navy) 8%, transparent);
  }
  .recipe-teaser__inner { max-width: 1280px; margin: 0 auto; }

  .recipe-teaser__header {
    text-align: center;
    margin: 0 auto clamp(2rem, 3.5vw, 3rem);
    max-width: 38rem;
  }
  .recipe-teaser__eyebrow { margin: 0 0 0.85rem; }
  .recipe-teaser__title {
    margin: 0 0 0.85rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.4rem, 5.5vw, 4.4rem);
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: var(--navy);
  }
  .recipe-teaser__title :global(em) {
    font-style: normal;
    color: var(--red);
  }
  .recipe-teaser__body {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.05rem, 1.5vw, 1.3rem);
    line-height: 1.55;
    color: var(--navy);
    opacity: 0.7;
  }

  .recipe-teaser__list {
    list-style: none;
    margin: 0 0 clamp(3rem, 5vw, 4.5rem);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  @media (max-width: 900px)  { .recipe-teaser__list { grid-template-columns: 1fr; gap: 2.5rem; } }

  .recipe-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-decoration: none;
    color: var(--navy);
  }
  .recipe-card__figure {
    margin: 0;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: color-mix(in srgb, var(--navy) 8%, var(--cream));
    border-radius: 4px;
  }
  .recipe-card__figure img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1100ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .recipe-card:hover .recipe-card__figure img { transform: scale(1.04); }

  .recipe-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .recipe-card__num {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: var(--red);
    opacity: 0.85;
  }
  .recipe-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.15rem, 1.6vw, 1.5rem);
    line-height: 1.2;
    letter-spacing: 0.005em;
    color: var(--navy);
  }
  .recipe-card__meta {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--navy);
    opacity: 0.55;
  }

  .recipe-teaser__cta {
    text-align: center;
  }

  [data-anim='up'] {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity var(--dur-divine) var(--ease-divine),
                transform var(--dur-divine) var(--ease-divine);
    transition-delay: calc(var(--i, 0) * 65ms);
  }
  [data-anim='up'].is-in { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    [data-anim='up'] { opacity: 1; transform: none; transition: none; }
    .recipe-card:hover .recipe-card__figure img { transform: none; }
  }
</style>

<script>
  if ('IntersectionObserver' in window) {
    const sec = document.querySelector<HTMLElement>('[data-recipe-teaser]');
    if (sec) {
      const items = sec.querySelectorAll<HTMLElement>('[data-anim="up"]');
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            items.forEach((el) => el.classList.add('is-in'));
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      io.observe(sec);
    }
  } else {
    document.querySelectorAll('[data-recipe-teaser] [data-anim="up"]').forEach((el) => el.classList.add('is-in'));
  }
</script>
