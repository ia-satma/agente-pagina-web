---
/**
 * Divider editorial con motivos florales mexicanos.
 * 100% SVG inline — cero PNG, cero halos blancos, color con currentColor.
 * Diferenciador clave vs Cloud23 — esto es marca pura AMBROSIA.
 *
 * variant:
 *   - "full"   — medallon otomi horizontal completo con drawing-on
 *   - "mini"   — single ornament SVG chico, para separadores discretos
 *   - "corner" — esquina decorativa SVG
 *
 * tone: ink (morado, default) | red | cyan | multicolor
 * animate: true | false (default true) — draw on scroll
 */

interface Props {
  variant?: 'full' | 'mini' | 'corner';
  tone?: 'ink' | 'red' | 'cyan' | 'multicolor';
  animate?: boolean;
  class?: string;
}

const {
  variant = 'full',
  tone = 'ink',
  animate = true,
  class: className = '',
} = Astro.props;

const id = `floral-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class:list={['floral', `floral--${variant}`, `floral--${tone}`, className]}
  data-floral={animate ? 'animate' : 'static'}
  data-floral-id={id}
>
  {variant === 'full' && (
    <svg
      class="floral__svg"
      viewBox="0 0 600 80"
      preserveAspectRatio="xMidYMid meet"
      role="presentation"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
    >
      <g class="floral__strokes" fill="none" stroke="currentColor" stroke-width="0.85" stroke-linecap="round" stroke-linejoin="round">
        {/* Linea horizontal principal con curvas otomi */}
        <path d="M30 40 H 215" data-stroke />
        <path d="M385 40 H 570" data-stroke />

        {/* Ornamentos laterales — espirales otomi */}
        <path d="M215 40 q 8 -10, 18 -8 q 8 2, 8 8 q 0 6, -6 8" data-stroke />
        <path d="M385 40 q -8 -10, -18 -8 q -8 2, -8 8 q 0 6, 6 8" data-stroke />

        {/* Hojas/cuernos centrales */}
        <path d="M255 40 q 6 -16, 18 -16 q 6 0, 8 6" data-stroke />
        <path d="M345 40 q -6 -16, -18 -16 q -6 0, -8 6" data-stroke />
        <path d="M275 40 q 4 -10, 12 -10" data-stroke />
        <path d="M325 40 q -4 -10, -12 -10" data-stroke />

        {/* Tallos inferiores simetricos */}
        <path d="M260 40 q 4 12, 14 14" data-stroke />
        <path d="M340 40 q -4 12, -14 14" data-stroke />
      </g>

      <g class="floral__flowers">
        {/* Flor central — primary */}
        <circle cx="300" cy="40" r="4.5" fill="currentColor" data-flower="primary" />
        <circle cx="300" cy="40" r="1.4" fill="var(--bg-page, #FBF7EF)" data-flower="primary-core" />

        {/* Petalos cardinales alrededor del centro */}
        <circle cx="300" cy="28" r="2" fill="currentColor" data-flower="accent" />
        <circle cx="300" cy="52" r="2" fill="currentColor" data-flower="accent" />
        <circle cx="288" cy="40" r="2" fill="currentColor" data-flower="secondary" />
        <circle cx="312" cy="40" r="2" fill="currentColor" data-flower="secondary" />

        {/* Flores satelite simetricas */}
        <circle cx="240" cy="22" r="2.5" fill="currentColor" data-flower="secondary" />
        <circle cx="360" cy="22" r="2.5" fill="currentColor" data-flower="secondary" />
        <circle cx="240" cy="58" r="1.6" fill="currentColor" data-flower="tertiary" />
        <circle cx="360" cy="58" r="1.6" fill="currentColor" data-flower="tertiary" />

        {/* Puntos decorativos en lineas laterales */}
        <circle cx="100" cy="40" r="1.4" fill="currentColor" data-flower="tertiary" />
        <circle cx="500" cy="40" r="1.4" fill="currentColor" data-flower="tertiary" />
        <circle cx="160" cy="40" r="1" fill="currentColor" data-flower="tertiary" />
        <circle cx="440" cy="40" r="1" fill="currentColor" data-flower="tertiary" />
      </g>
    </svg>
  )}

  {variant === 'mini' && (
    <svg
      viewBox="0 0 120 24"
      preserveAspectRatio="xMidYMid meet"
      role="presentation"
      aria-hidden="true"
    >
      <g class="floral__strokes" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
        <path d="M8 12 H 50" data-stroke />
        <path d="M70 12 H 112" data-stroke />
      </g>
      <g class="floral__flowers">
        <circle cx="60" cy="12" r="3" fill="currentColor" data-flower="primary" />
        <circle cx="60" cy="6" r="1.4" fill="currentColor" data-flower="accent" />
        <circle cx="60" cy="18" r="1.4" fill="currentColor" data-flower="accent" />
        <circle cx="54" cy="12" r="1.4" fill="currentColor" data-flower="secondary" />
        <circle cx="66" cy="12" r="1.4" fill="currentColor" data-flower="secondary" />
      </g>
    </svg>
  )}

  {variant === 'corner' && (
    <svg
      viewBox="0 0 60 60"
      preserveAspectRatio="xMidYMid meet"
      role="presentation"
      aria-hidden="true"
    >
      <g class="floral__strokes" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round">
        <path d="M4 56 V 30 Q 4 4, 30 4 H 56" data-stroke />
        <path d="M16 30 q 4 -8, 12 -8" data-stroke />
      </g>
      <g class="floral__flowers">
        <circle cx="30" cy="30" r="3" fill="currentColor" data-flower="primary" />
        <circle cx="30" cy="24" r="1.3" fill="currentColor" data-flower="accent" />
        <circle cx="36" cy="30" r="1.3" fill="currentColor" data-flower="accent" />
      </g>
    </svg>
  )}
</div>

<style>
  .floral {
    display: block;
    margin: 0 auto;
    line-height: 0;
    pointer-events: none;
    color: currentColor;
  }

  .floral--full {
    width: 100%;
    max-width: 560px;
    padding: 1rem 1rem;
  }
  .floral--mini {
    width: 120px;
    padding: 0.75rem 0;
  }
  .floral--corner {
    width: 56px;
    padding: 0;
  }

  .floral svg { width: 100%; height: auto; display: block; }

  /* Tonos */
  .floral--ink   { color: var(--navy); }
  .floral--red   { color: var(--color-red); }
  .floral--cyan  { color: var(--color-cyan); }

  /* Multicolor: 3 colores del brand book */
  .floral--multicolor [data-flower="primary"]   { fill: var(--color-red); color: var(--color-red); }
  .floral--multicolor [data-flower="secondary"] { fill: var(--color-cyan); color: var(--color-cyan); }
  .floral--multicolor [data-flower="accent"]    { fill: var(--navy); color: var(--navy); }
  .floral--multicolor [data-flower="tertiary"]  { fill: var(--color-red); color: var(--color-red); opacity: 0.55; }
  .floral--multicolor .floral__strokes          { stroke: var(--navy); opacity: 0.6; }

  /* Animacion draw-on-scroll */
  .floral [data-stroke] {
    stroke-dasharray: var(--len, 600);
    stroke-dashoffset: var(--len, 600);
    transition: stroke-dashoffset 1600ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .floral.is-in [data-stroke] {
    stroke-dashoffset: 0;
  }

  .floral [data-flower] {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(0.4);
    transition: opacity 700ms cubic-bezier(0.22, 1, 0.36, 1),
                transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .floral.is-in [data-flower] { opacity: 1; transform: scale(1); }
  .floral.is-in [data-flower="primary"]      { transition-delay: 700ms; }
  .floral.is-in [data-flower="primary-core"] { opacity: 1; transition-delay: 850ms; }
  .floral.is-in [data-flower="secondary"]    { transition-delay: 900ms; }
  .floral.is-in [data-flower="accent"]       { transition-delay: 1050ms; }
  .floral.is-in [data-flower="tertiary"]     { transition-delay: 1200ms; }

  @media (prefers-reduced-motion: reduce) {
    .floral [data-stroke] { stroke-dashoffset: 0; transition: none; }
    .floral [data-flower] { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  // Calcula la longitud real de cada path para draw preciso
  const all = document.querySelectorAll<SVGPathElement>('.floral [data-stroke]');
  all.forEach((path) => {
    try {
      const len = Math.ceil(path.getTotalLength());
      path.style.setProperty('--len', String(len));
    } catch { /* path may not be ready */ }
  });

  // Reveal cuando entra en viewport (una sola vez)
  if ('IntersectionObserver' in window) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-in');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.35 });
    document.querySelectorAll<HTMLElement>('.floral[data-floral="animate"]').forEach((el) => {
      if (reduce) el.classList.add('is-in');
      else io.observe(el);
    });
  } else {
    document.querySelectorAll<HTMLElement>('.floral').forEach((el) => el.classList.add('is-in'));
  }
</script>
