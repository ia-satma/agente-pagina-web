---
/**
 * BuyPoints — Boutique destinations redisenadas como hero alternantes.
 *
 * Cada punto es una card editorial full-width tipo "destination feature":
 *   - Bloque artistico (40%) con letra inicial XL (J / R) sobre fondo navy,
 *     patron geometrico ornamental, badge de distincion flotando.
 *   - Bloque info (60%) con numeral romano, nombre monumental, ubicacion
 *     con pin SVG, descripcion narrativa, divider, social row + CTA primario
 *     grande con flecha que se anima.
 *
 *   Alternancia desktop: punto 01 con bloque art a la izquierda, punto 02
 *   invertido (info izquierda, bloque art derecha). Esto da ritmo editorial.
 *
 *   Mobile (< 880px): apilado vertical, bloque art arriba.
 */
import { t, type Locale } from '~/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const c = (dict as any).donde.compra as {
  eyebrow: string;
  title: string;
  body: string;
  puntos: {
    nombre: string;
    lugar: string;
    desc: string;
    distincion: string;
    instagram: string;
    facebook: string;
    web: string;
    cta: string;
    ctaHref: string;
  }[];
};

const isES = locale === 'es';
const labelIG  = 'Instagram';
const labelFB  = 'Facebook';
const labelWeb = isES ? 'Sitio' : 'Site';
const romans   = ['I', 'II', 'III', 'IV'];
---

<section class="buy-points" data-buy-points>
  <div class="buy-points__inner">
    <header class="buy-points__header">
      <p class="eyebrow buy-points__eyebrow" data-reveal set:html={c.eyebrow}></p>
      <h2 class="buy-points__title" data-reveal set:html={c.title}></h2>
      <p class="buy-points__body" data-reveal set:html={c.body}></p>
    </header>

    <ol class="buy-points__list" role="list">
      {c.puntos.map((p, i) => {
        const initial = p.nombre.trim().charAt(0).toUpperCase();
        const roman = romans[i] ?? String(i + 1);
        // Mapeo de imagen ambiental por punto
        const ambientImages = ['/images/boutique/jabalina.webp', '/images/boutique/carnes-ramos.webp'];
        const ambientImg = ambientImages[i] ?? ambientImages[0];
        const ambientAlt = i === 0
          ? (isES ? 'Interior calido de Restaurante Jabalina con botella AMBROSIA' : 'Warm interior of Restaurante Jabalina with AMBROSIA bottle')
          : (isES ? 'Carniceria Carnes Ramos con cortes premium y botella AMBROSIA' : 'Carnes Ramos butcher shop with premium cuts and AMBROSIA bottle');
        return (
          <li class="boutique-card" data-i={i} style={`--i:${i};`}>
            {/* ─── Bloque artistico — foto ambiental + badge + numeral romano ─── */}
            <aside class="boutique-card__art" aria-hidden="false">
              <img class="boutique-card__art-img" src={ambientImg} alt={ambientAlt} loading="lazy" decoding="async" width="1600" height="2000" />
              <span class="boutique-card__art-overlay"></span>
              <span class="boutique-card__art-roman" aria-hidden="true">{roman}</span>
              <span class="boutique-card__art-badge">
                <span class="boutique-card__art-badge-dot"></span>
                {p.distincion}
              </span>
            </aside>

            {/* ─── Bloque info ─── */}
            <div class="boutique-card__info">
              <header class="boutique-card__head" data-reveal>
                <p class="boutique-card__index">
                  <span class="boutique-card__index-dot"></span>
                  {isES ? 'Punto' : 'Point'} 0{i + 1} {isES ? 'de' : 'of'} 0{c.puntos.length}
                </p>
                <h3 class="boutique-card__name">{p.nombre}</h3>
                <p class="boutique-card__where">
                  <svg class="boutique-card__pin" width="14" height="17" viewBox="0 0 11 14" fill="none" aria-hidden="true">
                    <path d="M5.5 13s4-4.2 4-7.5a4 4 0 1 0-8 0c0 3.3 4 7.5 4 7.5z" stroke="currentColor" stroke-width="1.3" fill="none" />
                    <circle cx="5.5" cy="5.5" r="1.6" fill="currentColor" />
                  </svg>
                  <span>{p.lugar}</span>
                </p>
              </header>

              <p class="boutique-card__desc" data-reveal>{p.desc}</p>

              <div class="boutique-card__divider" aria-hidden="true">
                <span class="boutique-card__divider-line"></span>
                <span class="boutique-card__divider-glyph">·</span>
                <span class="boutique-card__divider-line"></span>
              </div>

              {/* CTA primario grande + social row */}
              <div class="boutique-card__actions" data-reveal>
                <a class="boutique-card__cta" href={p.ctaHref} target="_blank" rel="noopener noreferrer">
                  <span class="boutique-card__cta-label">{p.cta}</span>
                  <span class="boutique-card__cta-arrow">
                    <svg width="18" height="12" viewBox="0 0 18 12" fill="none" aria-hidden="true">
                      <path d="M0 6h16M11 1l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </a>

                <ul class="boutique-card__social" role="list">
                  <li>
                    <a class="boutique-card__social-link" href={p.instagram} target="_blank" rel="noopener noreferrer" aria-label={`${p.nombre} — ${labelIG}`}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.5" />
                        <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5" />
                        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
                      </svg>
                      <span class="sr-only">{labelIG}</span>
                    </a>
                  </li>
                  <li>
                    <a class="boutique-card__social-link" href={p.facebook} target="_blank" rel="noopener noreferrer" aria-label={`${p.nombre} — ${labelFB}`}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M15 3h-3a4 4 0 0 0-4 4v3H5v4h3v7h4v-7h3l1-4h-4V7a1 1 0 0 1 1-1h3V3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                      </svg>
                      <span class="sr-only">{labelFB}</span>
                    </a>
                  </li>
                  <li>
                    <a class="boutique-card__social-link" href={p.web} target="_blank" rel="noopener noreferrer" aria-label={`${p.nombre} — ${labelWeb}`}>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5" />
                        <path d="M3 12h18M12 3c2.5 3 2.5 15 0 18M12 3c-2.5 3-2.5 15 0 18" stroke="currentColor" stroke-width="1.5" />
                      </svg>
                      <span class="sr-only">{labelWeb}</span>
                    </a>
                  </li>
                </ul>
              </div>
            </div>
          </li>
        );
      })}
    </ol>
  </div>
</section>

<style>
  .buy-points {
    background: var(--bg-page);
    color: var(--navy);
    padding: clamp(4rem, 8vw, 7rem) 1.5rem;
  }
  .buy-points__inner { max-width: 1340px; margin: 0 auto; }

  .buy-points__header {
    max-width: 40rem;
    margin: 0 auto clamp(3rem, 5vw, 4.5rem);
    text-align: center;
  }
  .buy-points__eyebrow {
    margin: 0 0 1rem;
    color: var(--red);
    opacity: 0.85;
  }
  .buy-points__title {
    margin: 0 0 1.15rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.4rem, 5.5vw, 4.4rem);
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: var(--navy);
  }
  .buy-points__title :global(em.brand) {
    font-style: normal;
    color: var(--red);
  }
  .buy-points__body {
    margin: 0 auto;
    max-width: 32rem;
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--navy);
    opacity: 0.78;
  }

  /* ─── Lista vertical de cards monumentales ─── */
  .buy-points__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 4.5rem);
  }

  /* ─── Card ─── */
  .boutique-card {
    --card-accent: var(--red);
    --card-bg: var(--bg-page);

    position: relative;
    display: grid;
    grid-template-columns: minmax(280px, 0.85fr) minmax(0, 1.15fr);
    align-items: stretch;
    min-height: 460px;
    border: 1px solid color-mix(in srgb, var(--navy) 14%, transparent);
    border-radius: 6px;
    overflow: hidden;
    background: var(--card-bg);
    transition:
      transform var(--dur-medium) var(--ease-medium),
      border-color var(--dur-medium) var(--ease-medium),
      box-shadow var(--dur-medium) var(--ease-medium);
  }
  .boutique-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--card-accent) 30%, transparent);
    box-shadow:
      0 36px 70px -42px color-mix(in srgb, var(--navy) 60%, transparent),
      0 14px 28px -16px color-mix(in srgb, var(--card-accent) 28%, transparent);
  }
  /* Punto par (II): invierte el orden — info a la izquierda, art a la derecha */
  .boutique-card[data-i="1"] {
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
  }
  .boutique-card[data-i="1"] .boutique-card__art {
    order: 2;
  }

  /* ─── Bloque artistico: imagen ambiental + overlay editorial ─── */
  .boutique-card__art {
    position: relative;
    background: var(--navy);
    color: var(--cream);
    overflow: hidden;
    isolation: isolate;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 320px;
  }
  /* Imagen de fondo */
  .boutique-card__art-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    transition: transform 1.8s cubic-bezier(0.16, 1, 0.3, 1),
                filter var(--dur-divine) var(--ease-divine);
  }
  .boutique-card:hover .boutique-card__art-img {
    transform: scale(1.06);
    filter: saturate(1.08) brightness(1.02);
  }
  /* Overlay degradado para legibilidad de letter + badge */
  .boutique-card__art-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(135deg,
        color-mix(in srgb, var(--navy) 70%, transparent) 0%,
        color-mix(in srgb, var(--navy) 35%, transparent) 45%,
        color-mix(in srgb, var(--navy) 55%, transparent) 100%
      );
    transition: background var(--dur-medium) var(--ease-medium);
  }
  .boutique-card:hover .boutique-card__art-overlay {
    background:
      linear-gradient(135deg,
        color-mix(in srgb, var(--navy) 60%, transparent) 0%,
        color-mix(in srgb, var(--navy) 25%, transparent) 45%,
        color-mix(in srgb, var(--navy) 45%, transparent) 100%
      );
  }
  /* Letter art removida — la foto ambiental es protagonista */
  /* Numeral romano top-left */
  .boutique-card__art-roman {
    position: absolute;
    top: clamp(1.25rem, 2.5vw, 2rem);
    left: clamp(1.25rem, 2.5vw, 2rem);
    z-index: 3;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    line-height: 1;
    color: var(--cream);
    opacity: 0.6;
    letter-spacing: 0.05em;
  }
  /* Badge de distincion flotante bottom-left */
  .boutique-card__art-badge {
    position: absolute;
    bottom: clamp(1.25rem, 2.5vw, 2rem);
    left: clamp(1.25rem, 2.5vw, 2rem);
    right: clamp(1.25rem, 2.5vw, 2rem);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.95rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cream);
    background: color-mix(in srgb, var(--cream) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--cream) 28%, transparent);
    border-radius: 999px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    width: fit-content;
  }
  .boutique-card__art-badge-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--red);
    animation: boutique-pulse 2.6s ease-in-out infinite;
  }
  /* Ornamento SVG en esquina sup-derecha */
  .boutique-card__art-ornament {
    position: absolute;
    top: 0;
    right: 0;
    width: clamp(100px, 14vw, 160px);
    height: auto;
    color: var(--red);
    opacity: 0.7;
    z-index: 1;
    pointer-events: none;
    transform: translate(20%, -20%);
  }

  /* ─── Bloque info ─── */
  .boutique-card__info {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1.75rem, 3.5vw, 3rem) clamp(1.75rem, 3vw, 2.75rem);
  }

  .boutique-card__head {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .boutique-card__index {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--red);
  }
  .boutique-card__index-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--red);
  }
  .boutique-card__name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.75rem, 3.4vw, 2.6rem);
    line-height: 1.1;
    letter-spacing: 0.005em;
    color: var(--navy);
    text-wrap: balance;
  }
  .boutique-card__where {
    margin: 0.3rem 0 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--navy);
    opacity: 0.65;
  }
  .boutique-card__pin {
    flex-shrink: 0;
    color: var(--red);
  }

  .boutique-card__desc {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.05rem, 1.5vw, 1.3rem);
    line-height: 1.55;
    color: var(--navy);
    opacity: 0.78;
    max-width: 42ch;
  }

  /* Divider ornamentado */
  .boutique-card__divider {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 0.5rem 0;
  }
  .boutique-card__divider-line {
    flex: 1;
    height: 1px;
    background: color-mix(in srgb, var(--navy) 16%, transparent);
  }
  .boutique-card__divider-glyph {
    font-family: var(--font-display);
    color: var(--red);
    font-size: 1.5rem;
    line-height: 0;
  }

  /* Actions: CTA principal + social row */
  .boutique-card__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .boutique-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.95rem 1.5rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #FFFFFF;
    background: var(--red);
    text-decoration: none;
    border-radius: 999px;
    transition:
      background-color var(--dur-medium) var(--ease-medium),
      transform var(--dur-medium) var(--ease-medium),
      gap var(--dur-medium) var(--ease-medium),
      box-shadow var(--dur-medium) var(--ease-medium);
  }
  .boutique-card__cta:hover {
    background: color-mix(in srgb, var(--red) 88%, var(--navy));
    transform: translateY(-2px);
    gap: 1.15rem;
    box-shadow: 0 14px 28px -14px color-mix(in srgb, var(--red) 60%, transparent);
  }
  .boutique-card__cta-arrow {
    display: inline-flex;
    align-items: center;
    transition: transform var(--dur-medium) var(--ease-medium);
  }
  .boutique-card__cta:hover .boutique-card__cta-arrow {
    transform: translateX(3px);
  }

  /* Social row */
  .boutique-card__social {
    list-style: none;
    margin: 0;
    padding: 0;
    display: inline-flex;
    gap: 0.45rem;
  }
  .boutique-card__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    color: var(--navy);
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--navy) 18%, transparent);
    text-decoration: none;
    transition:
      background-color var(--dur-medium) var(--ease-medium),
      border-color var(--dur-medium) var(--ease-medium),
      color var(--dur-medium) var(--ease-medium),
      transform var(--dur-medium) var(--ease-medium);
  }
  .boutique-card__social-link:hover {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--cream);
    transform: translateY(-2px);
  }

  /* Sr-only para a11y */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Animaciones */
  @keyframes boutique-pulse {
    0%, 100% { transform: scale(1);    opacity: 1; }
    50%      { transform: scale(1.4);  opacity: 0.5; }
  }

  /* Reveal */
  [data-reveal] {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity var(--dur-divine) var(--ease-divine),
      transform var(--dur-divine) var(--ease-divine);
    transition-delay: calc(var(--i, 0) * 60ms);
  }
  [data-reveal].is-in { opacity: 1; transform: translateY(0); }

  /* ─── Tablet / Mobile ─── */
  @media (max-width: 880px) {
    .boutique-card,
    .boutique-card[data-i="1"] {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .boutique-card[data-i="1"] .boutique-card__art {
      order: 0;
    }
    .boutique-card__art {
      min-height: 240px;
      aspect-ratio: 16 / 9;
    }
    .boutique-card__art-badge {
      bottom: 1rem;
      left: 1rem;
      right: 1rem;
    }
    .boutique-card__actions {
      flex-direction: column;
      align-items: stretch;
    }
    .boutique-card__cta {
      justify-content: center;
    }
    .boutique-card__social {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .boutique-card:hover { transform: none; }
    .boutique-card__art-badge-dot { animation: none; }
    .boutique-card__cta:hover { transform: none; }
    [data-reveal] { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  if ('IntersectionObserver' in window) {
    const sec = document.querySelector<HTMLElement>('[data-buy-points]');
    if (sec) {
      const items = sec.querySelectorAll<HTMLElement>('[data-reveal]');
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            items.forEach((el) => el.classList.add('is-in'));
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      io.observe(sec);
    }
  } else {
    document.querySelectorAll('[data-buy-points] [data-reveal]').forEach((el) => el.classList.add('is-in'));
  }
</script>
