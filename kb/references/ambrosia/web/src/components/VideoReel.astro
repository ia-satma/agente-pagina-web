---
/**
 * VideoReel — Seccion editorial de videos en 1080p.
 *
 * Disenado para 1–3 videos en 16:9 (1080p nativos). Autoplay muted loop con
 * IntersectionObserver (pausa fuera de viewport → ahorra bateria en mobile).
 *
 * Para anadir tus videos: subirlos a `public/video/` (formato .webm + .mp4
 * fallback) y declararlos en el array `videos` abajo, o pasarlos como prop.
 *
 * Mientras no haya archivos: cada slot muestra un placeholder editorial
 * (eyebrow + numeral + hint "1080p video pendiente").
 */
interface VideoItem {
  /** Ruta al .webm (preferido) o .mp4 */
  src: string;
  /** Ruta al .mp4 fallback (opcional si src ya es mp4) */
  srcMp4?: string;
  /** Poster image (jpg/webp) — se muestra antes de cargar */
  poster?: string;
  /** Caption editorial debajo del video */
  caption?: string;
}

interface Props {
  /** Lista de videos. Si vacia, muestra 3 placeholders en grid. */
  videos?: VideoItem[];
  /** Eyebrow de seccion */
  eyebrow?: string;
  /** Titulo de seccion (HTML permitido) */
  title?: string;
  /** Bajada opcional */
  body?: string;
}

const {
  videos = [],
  eyebrow = 'En movimiento',
  title = 'La salsa <em>en escena</em>',
  body = 'Tres momentos del ritual capturados en 1080p.',
} = Astro.props;

// Mientras no haya videos, mostramos 3 placeholders editoriales.
// Tipamos explícitamente como VideoItem[] para que TS sepa que las props
// opcionales srcMp4 y poster pueden existir en cualquier slot.
const slots: VideoItem[] = videos.length > 0 ? videos : Array.from({ length: 3 }, () => ({ src: '', caption: '' }));
---

<section class="video-reel" data-video-reel>
  <div class="video-reel__inner">
    <header class="video-reel__header">
      <p class="eyebrow video-reel__eyebrow" data-anim="up">{eyebrow}</p>
      <h2 class="video-reel__title" data-anim="up" set:html={title}></h2>
      {body && <p class="video-reel__body" data-anim="up">{body}</p>}
    </header>

    <ol class="video-reel__timeline" role="list">
      {slots.map((v, i) => (
        <li class="video-reel__chapter" data-anim="up" style={`--i:${i}`}>
          <aside class="video-reel__rail" aria-hidden="true">
            <span class="video-reel__rail-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="video-reel__rail-dot"></span>
            {i < slots.length - 1 && <span class="video-reel__rail-line"></span>}
          </aside>

          <figure
            class="video-reel__figure"
            data-video-card
            data-caption={v.caption ?? ''}
            data-chapter={String(i + 1).padStart(2, '0')}
            data-src={v.src ?? ''}
            data-src-mp4={v.srcMp4 ?? ''}
            data-poster={v.poster ?? ''}
            tabindex={v.src ? 0 : -1}
            role={v.src ? 'button' : undefined}
            aria-label={v.src ? `Abrir video ${i + 1}: ${v.caption ?? ''}` : undefined}
          >
            {v.src ? (
              <>
                <video
                  class="video-reel__video"
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  poster={v.poster}
                  aria-label={v.caption || `Video ${i + 1}`}
                >
                  {v.src.endsWith('.webm') && <source src={v.src} type="video/webm" />}
                  {v.srcMp4 && <source src={v.srcMp4} type="video/mp4" />}
                  {v.src.endsWith('.mp4') && <source src={v.src} type="video/mp4" />}
                </video>

                {/* Controles custom — pausa + volumen */}
                <div class="video-reel__controls" aria-hidden="false">
                  <button
                    type="button"
                    class="video-reel__ctrl video-reel__ctrl--play"
                    data-action="toggle-play"
                    aria-label="Reproducir o pausar"
                  >
                    {/* Pause (default mientras reproduce) */}
                    <svg class="ic ic--pause" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <rect x="3"  y="2" width="3" height="10" fill="currentColor" />
                      <rect x="8"  y="2" width="3" height="10" fill="currentColor" />
                    </svg>
                    {/* Play (cuando esta pausado) */}
                    <svg class="ic ic--play" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path d="M3 2l9 5-9 5V2z" fill="currentColor" />
                    </svg>
                  </button>

                  <button
                    type="button"
                    class="video-reel__ctrl video-reel__ctrl--mute"
                    data-action="toggle-mute"
                    aria-label="Activar o silenciar sonido"
                  >
                    {/* Muted (default) */}
                    <svg class="ic ic--muted" width="16" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true">
                      <path d="M1 5v4h3l4 3V2L4 5H1z" fill="currentColor" />
                      <path d="M11 4l5 6M16 4l-5 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                    {/* Sonido on */}
                    <svg class="ic ic--sound" width="16" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true">
                      <path d="M1 5v4h3l4 3V2L4 5H1z" fill="currentColor" />
                      <path d="M12 5c1 1 1 3 0 4M14 3c2 2 2 6 0 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none" />
                    </svg>
                  </button>
                </div>
              </>
            ) : (
              <div class="video-reel__placeholder" aria-hidden="true">
                <span class="video-reel__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="video-reel__hint">Video 1080p · pendiente</span>
                <svg class="video-reel__play" width="42" height="42" viewBox="0 0 42 42" fill="none">
                  <circle cx="21" cy="21" r="20" stroke="currentColor" stroke-width="1.2" />
                  <path d="M16 13l13 8-13 8V13z" fill="currentColor" />
                </svg>
              </div>
            )}
            {/* Overlay con gradient + texto sobre el video */}
            {v.src && v.caption && (
              <div class="video-reel__overlay" aria-hidden="true">
                <p class="video-reel__chapter-label">Momento {String(i + 1).padStart(2, '0')}</p>
                <p class="video-reel__caption">{v.caption}</p>
                <span class="video-reel__open-hint">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                    <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  Ver en grande
                </span>
              </div>
            )}

            <span class="video-reel__frame" aria-hidden="true"></span>
          </figure>
        </li>
      ))}
    </ol>

    {/* ─── Lightbox: modal con el video a tamano grande + audio activo ─── */}
    <div class="video-reel__lightbox" data-lightbox hidden aria-modal="true" role="dialog">
      <button class="video-reel__lightbox-close" data-lightbox-close type="button" aria-label="Cerrar video">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <div class="video-reel__lightbox-stage">
        <video
          class="video-reel__lightbox-video"
          data-lightbox-video
          controls
          playsinline
          preload="auto"
        ></video>
        <p class="video-reel__lightbox-caption" data-lightbox-caption></p>
      </div>
    </div>
  </div>
</section>

<style>
  .video-reel {
    background: var(--bg-page);
    color: var(--navy);
    padding: clamp(3.5rem, 7vw, 6rem) 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--navy) 8%, transparent);
  }
  .video-reel__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .video-reel__header {
    text-align: center;
  }

  .video-reel__header {
    text-align: center;
    margin: 0 auto clamp(1.75rem, 3.5vw, 3rem);
    max-width: 36rem;
  }
  .video-reel__eyebrow { margin: 0 0 0.85rem; }
  .video-reel__title {
    margin: 0 0 0.85rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.4rem, 5.5vw, 4.4rem);
    line-height: 1.08;
    letter-spacing: 0.02em;
    color: var(--navy);
  }
  .video-reel__title :global(em) {
    font-style: normal;
    color: var(--red);
  }
  .video-reel__body {
    margin: 0;
    font-size: clamp(1.05rem, 1.5vw, 1.3rem);
    line-height: 1.6;
    color: var(--navy);
    opacity: 0.72;
  }

  /* ─── Timeline editorial vertical ─── */
  .video-reel__timeline {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 1200px;
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4.5vw, 4rem);
    counter-reset: chapter;
  }
  .video-reel__chapter {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: clamp(1.25rem, 2.5vw, 2rem);
    align-items: start;
  }

  /* Rail con numeral monumental + dot + linea */
  .video-reel__rail {
    position: relative;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.4rem;
  }
  .video-reel__rail-num {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: color-mix(in srgb, var(--navy) 22%, transparent);
    font-variant-numeric: lining-nums;
    transition: color var(--dur-medium) var(--ease-medium);
  }
  .video-reel__chapter:hover .video-reel__rail-num,
  .video-reel__chapter.is-active .video-reel__rail-num {
    color: var(--red);
  }
  .video-reel__rail-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    margin-top: 1.2rem;
    background: var(--bg-page);
    border: 1.5px solid color-mix(in srgb, var(--navy) 38%, transparent);
    transition: background var(--dur-medium) var(--ease-medium),
                border-color var(--dur-medium) var(--ease-medium),
                transform var(--dur-medium) var(--ease-medium);
  }
  .video-reel__chapter:hover .video-reel__rail-dot,
  .video-reel__chapter.is-active .video-reel__rail-dot {
    background: var(--red);
    border-color: var(--red);
    transform: scale(1.18);
  }
  .video-reel__rail-line {
    flex: 1;
    width: 1px;
    margin-top: 1rem;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--navy) 28%, transparent) 0%,
      color-mix(in srgb, var(--navy) 12%, transparent) 80%,
      transparent 100%
    );
  }

  /* Figure (video) — mucho mas grande */
  .video-reel__figure {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 6px;
    background: var(--navy);
    isolation: isolate;
    box-shadow:
      0 30px 60px -40px color-mix(in srgb, var(--navy) 55%, transparent),
      0 10px 22px -14px color-mix(in srgb, var(--navy) 30%, transparent);
    transition: transform var(--dur-medium) var(--ease-medium),
                box-shadow var(--dur-medium) var(--ease-medium);
  }
  .video-reel__chapter:hover .video-reel__figure {
    transform: translateY(-3px);
    box-shadow:
      0 40px 75px -38px color-mix(in srgb, var(--navy) 60%, transparent),
      0 14px 28px -14px color-mix(in srgb, var(--navy) 38%, transparent);
  }

  /* ─── Overlay: gradient + texto editorial centrado-izquierda ───
     Diseno:
       - Gradient HORIZONTAL (izquierda oscura, derecha clara)
         garantiza legibilidad del texto sin tapar la imagen completa.
       - Texto vertically centered, anchored a la izquierda con padding generoso.
       - Capa adicional sutil de oscurecimiento global para mejor contraste. */
  .video-reel__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;        /* CENTRO vertical */
    align-items: flex-start;        /* IZQUIERDA horizontal */
    padding: clamp(1.5rem, 4vw, 3.5rem);
    background:
      /* Capa 1: gradient horizontal con base oscura a la izquierda */
      linear-gradient(
        to right,
        color-mix(in srgb, #000 82%, transparent) 0%,
        color-mix(in srgb, #000 70%, transparent) 25%,
        color-mix(in srgb, #000 35%, transparent) 55%,
        color-mix(in srgb, #000 8%, transparent) 80%,
        transparent 100%
      ),
      /* Capa 2: tinte navy global muy sutil */
      color-mix(in srgb, var(--navy) 14%, transparent);
    pointer-events: none;
    transition: background var(--dur-medium) var(--ease-medium);
  }
  .video-reel__chapter:hover .video-reel__overlay {
    background:
      linear-gradient(
        to right,
        color-mix(in srgb, #000 88%, transparent) 0%,
        color-mix(in srgb, #000 75%, transparent) 30%,
        color-mix(in srgb, #000 40%, transparent) 60%,
        color-mix(in srgb, #000 10%, transparent) 85%,
        transparent 100%
      ),
      color-mix(in srgb, var(--navy) 18%, transparent);
  }

  .video-reel__chapter-label {
    margin: 0 0 0.85rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(0.7rem, 0.95vw, 0.85rem);
    letter-spacing: 0.36em;
    text-transform: uppercase;
    color: #FFFFFF;
    opacity: 1;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.8), 0 0 1px rgba(0, 0, 0, 0.4);
  }
  .video-reel__chapter-label::before {
    content: '';
    display: inline-block;
    width: 28px;
    height: 1px;
    margin-right: 0.85rem;
    background: var(--red);
    vertical-align: middle;
  }

  .video-reel__caption {
    margin: 0;
    max-width: 26ch;             /* Texto en columna estrecha para mejor lectura */
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.4rem, 2.8vw, 2.4rem);
    line-height: 1.18;
    letter-spacing: 0.01em;
    color: #FFFFFF;              /* Blanco puro, maximo contraste */
    text-shadow:
      0 2px 16px rgba(0, 0, 0, 0.75),
      0 0 30px rgba(0, 0, 0, 0.45);
  }

  .video-reel__open-hint {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 1.1rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #FFFFFF;
    background: color-mix(in srgb, var(--red) 80%, transparent);
    border: 1px solid color-mix(in srgb, #FFFFFF 25%, transparent);
    border-radius: 999px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: background var(--dur-medium) var(--ease-medium),
                transform var(--dur-medium) var(--ease-medium);
  }
  .video-reel__chapter:hover .video-reel__open-hint {
    background: var(--red);
    transform: translateY(-1px);
  }

  /* Figure clickable */
  .video-reel__figure[role="button"] {
    cursor: pointer;
  }
  .video-reel__figure[role="button"]:focus-visible {
    outline: 2px solid var(--red);
    outline-offset: 3px;
  }

  /* ─── Lightbox: video grande con audio ─── */
  .video-reel__lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, #000 86%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: clamp(1rem, 3vw, 2.5rem);
    animation: lightbox-in 220ms ease-out;
  }
  .video-reel__lightbox[hidden] { display: none; }
  @keyframes lightbox-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .video-reel__lightbox-stage {
    position: relative;
    max-width: 1400px;
    max-height: 86vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .video-reel__lightbox-video {
    width: 100%;
    max-height: 78vh;
    border-radius: 6px;
    background: var(--navy);
    box-shadow: 0 40px 80px -30px rgba(0, 0, 0, 0.55);
    display: block;
  }
  .video-reel__lightbox-caption {
    margin: 0;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    color: var(--cream);
    opacity: 0.78;
    letter-spacing: 0.01em;
  }
  .video-reel__lightbox-close {
    position: absolute;
    top: clamp(0.85rem, 2vw, 1.5rem);
    right: clamp(0.85rem, 2vw, 1.5rem);
    z-index: 2;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--cream);
    background: color-mix(in srgb, var(--navy) 70%, transparent);
    border: 1px solid color-mix(in srgb, var(--cream) 32%, transparent);
    border-radius: 999px;
    cursor: pointer;
    transition: background var(--dur-medium) var(--ease-medium),
                border-color var(--dur-medium) var(--ease-medium),
                transform var(--dur-medium) var(--ease-medium);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .video-reel__lightbox-close:hover,
  .video-reel__lightbox-close:focus-visible {
    background: var(--red);
    border-color: var(--red);
    color: #FFFFFF;
    transform: scale(1.06);
    outline: none;
  }

  /* Mobile: rail mas compacto + bloque texto va abajo */
  @media (max-width: 720px) {
    .video-reel__chapter {
      grid-template-columns: 40px 1fr;
      gap: 0.85rem;
    }
    .video-reel__rail-num { font-size: 1.4rem; }
    .video-reel__rail-dot { margin-top: 0.65rem; }
  }
  @media (max-width: 480px) {
    .video-reel__chapter {
      grid-template-columns: 1fr;
    }
    .video-reel__rail {
      flex-direction: row;
      align-items: center;
      gap: 0.65rem;
      padding-top: 0;
    }
    .video-reel__rail-num { font-size: 1.1rem; }
    .video-reel__rail-line { display: none; }
  }

  .video-reel__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Placeholder cuando no hay video aun */
  .video-reel__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background:
      linear-gradient(135deg,
        color-mix(in srgb, var(--navy) 92%, var(--red)) 0%,
        var(--navy) 100%);
    color: var(--cream);
    grid-template-rows: auto auto auto;
    gap: 0.85rem;
    padding: 1.5rem;
    text-align: center;
  }
  .video-reel__num {
    align-self: end;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: color-mix(in srgb, var(--cream) 28%, transparent);
    font-variant-numeric: lining-nums;
  }
  .video-reel__play {
    align-self: center;
    color: color-mix(in srgb, var(--cream) 75%, transparent);
    transition: transform var(--dur-medium) var(--ease-medium), color var(--dur-medium) var(--ease-medium);
  }
  .video-reel__figure:hover .video-reel__play {
    color: var(--red);
    transform: scale(1.08);
  }
  .video-reel__hint {
    align-self: start;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  /* Marco fino estilo museo */
  .video-reel__frame {
    position: absolute;
    inset: 10px;
    border: 1px solid color-mix(in srgb, var(--cream) 28%, transparent);
    pointer-events: none;
    z-index: 1;
  }

  /* ─── Controles custom (play/pause + mute) ───
     Esquina inferior-derecha. Sutil por default, opacidad sube en hover/focus.
     En touch siempre visibles. */
  .video-reel__controls {
    position: absolute;
    bottom: 14px;
    right: 14px;
    z-index: 3;
    display: inline-flex;
    gap: 0.4rem;
    opacity: 0.65;
    transition: opacity var(--dur-medium) var(--ease-medium);
  }
  .video-reel__figure:hover .video-reel__controls,
  .video-reel__figure:focus-within .video-reel__controls {
    opacity: 1;
  }
  .video-reel__ctrl {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: color-mix(in srgb, var(--navy) 78%, transparent);
    color: var(--cream);
    border: 1px solid color-mix(in srgb, var(--cream) 28%, transparent);
    border-radius: 999px;
    cursor: pointer;
    transition:
      background-color var(--dur-medium) var(--ease-medium),
      border-color var(--dur-medium) var(--ease-medium),
      color var(--dur-medium) var(--ease-medium),
      transform var(--dur-medium) var(--ease-medium);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .video-reel__ctrl:hover,
  .video-reel__ctrl:focus-visible {
    background: var(--red);
    border-color: var(--red);
    color: #FFFFFF;
    transform: translateY(-1px);
    outline: none;
  }
  .video-reel__ctrl .ic { display: block; }

  /* Toggle de iconos segun estado del video */
  .video-reel__ctrl--play .ic--play  { display: none; }
  .video-reel__ctrl--play .ic--pause { display: block; }
  .video-reel__ctrl--play[data-paused="true"] .ic--play  { display: block; }
  .video-reel__ctrl--play[data-paused="true"] .ic--pause { display: none; }

  .video-reel__ctrl--mute .ic--sound { display: none; }
  .video-reel__ctrl--mute .ic--muted { display: block; }
  .video-reel__ctrl--mute[data-muted="false"] .ic--sound { display: block; }
  .video-reel__ctrl--mute[data-muted="false"] .ic--muted { display: none; }

  /* Touch devices: controles siempre visibles */
  @media (hover: none) and (pointer: coarse) {
    .video-reel__controls { opacity: 1; }
  }

  /* Reveal con stagger */
  [data-anim='up'] {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity var(--dur-divine) var(--ease-divine),
      transform var(--dur-divine) var(--ease-divine);
    transition-delay: calc(var(--i, 0) * 70ms);
  }
  [data-anim='up'].is-in {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    [data-anim='up'] { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  /**
   * VideoReel runtime
   *  - Reveal con stagger
   *  - Autoplay/pause segun viewport (battery saver)
   *  - Controles custom: play/pause + mute toggle
   *  - Respeta pausa manual: si el usuario pausa, NO auto-resume al re-entrar
   *  - Default: muted (no auto-suena, politica de browsers + decision brand)
   */
  const sec = document.querySelector<HTMLElement>('[data-video-reel]');
  if (sec) {
    const reveals = sec.querySelectorAll<HTMLElement>('[data-anim="up"]');
    const cards   = sec.querySelectorAll<HTMLElement>('[data-video-card]');

    if ('IntersectionObserver' in window) {
      const revealIO = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            reveals.forEach((el) => el.classList.add('is-in'));
            revealIO.unobserve(e.target);
          }
        });
      }, { threshold: 0.15 });
      revealIO.observe(sec);
    } else {
      reveals.forEach((el) => el.classList.add('is-in'));
    }

    // ─── Lightbox singleton ───
    const lightbox = sec.querySelector<HTMLElement>('[data-lightbox]');
    const lightboxVideo = sec.querySelector<HTMLVideoElement>('[data-lightbox-video]');
    const lightboxCaption = sec.querySelector<HTMLElement>('[data-lightbox-caption]');
    const lightboxClose = sec.querySelector<HTMLButtonElement>('[data-lightbox-close]');

    function openLightbox(card: HTMLElement) {
      if (!lightbox || !lightboxVideo) return;
      const src = card.dataset.src ?? '';
      const srcMp4 = card.dataset.srcMp4 ?? '';
      const poster = card.dataset.poster ?? '';
      const caption = card.dataset.caption ?? '';

      // Limpia sources previos y agrega nuevos
      lightboxVideo.innerHTML = '';
      if (src) {
        const s1 = document.createElement('source');
        s1.src = src;
        s1.type = src.endsWith('.webm') ? 'video/webm' : 'video/mp4';
        lightboxVideo.appendChild(s1);
      }
      if (srcMp4) {
        const s2 = document.createElement('source');
        s2.src = srcMp4;
        s2.type = 'video/mp4';
        lightboxVideo.appendChild(s2);
      }
      if (poster) lightboxVideo.poster = poster;
      if (lightboxCaption) lightboxCaption.textContent = caption;

      // Audio activo en el lightbox
      lightboxVideo.muted = false;
      lightboxVideo.volume = 0.8;
      lightboxVideo.load();

      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';

      lightboxVideo.play().catch(() => {/* user gesture not granted, mostrara controls */});
    }

    function closeLightbox() {
      if (!lightbox || !lightboxVideo) return;
      lightboxVideo.pause();
      lightboxVideo.removeAttribute('src');
      lightboxVideo.innerHTML = '';
      lightbox.hidden = true;
      document.body.style.overflow = '';
    }

    lightboxClose?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => {
      // click en backdrop (fuera del video) cierra
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox && !lightbox.hidden) closeLightbox();
    });

    // Por cada card: setup de controles + observer dedicado
    cards.forEach((card) => {
      const video = card.querySelector<HTMLVideoElement>('.video-reel__video');
      const playBtn = card.querySelector<HTMLButtonElement>('[data-action="toggle-play"]');
      const muteBtn = card.querySelector<HTMLButtonElement>('[data-action="toggle-mute"]');
      if (!video) return;

      // ─── Click en la card → abre lightbox ───
      const openOnInteract = (e: Event) => {
        // Si vino de un boton de control, ignorar
        const target = e.target as HTMLElement;
        if (target.closest('.video-reel__ctrl')) return;
        openLightbox(card);
      };
      card.addEventListener('click', openOnInteract);
      card.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          openLightbox(card);
        }
      });

      // Evita que los controles propaguen click hasta la card
      [playBtn, muteBtn].forEach((b) => {
        b?.addEventListener('click', (e) => e.stopPropagation());
      });

      // Estado interno: si el usuario pausa manualmente, lo respetamos
      let userPaused = false;

      function syncIcons() {
        if (playBtn) playBtn.dataset.paused = String(video!.paused);
        if (muteBtn) muteBtn.dataset.muted = String(video!.muted);
      }

      // Toggle play/pause manual
      playBtn?.addEventListener('click', () => {
        if (video.paused) {
          userPaused = false;
          video.play().catch(() => {});
        } else {
          userPaused = true;
          video.pause();
        }
        syncIcons();
      });

      // Toggle mute
      muteBtn?.addEventListener('click', () => {
        video.muted = !video.muted;
        if (!video.muted && video.volume === 0) video.volume = 0.7;
        syncIcons();
      });

      // Sync iniciales
      video.muted = true;
      syncIcons();
      video.addEventListener('play',  syncIcons);
      video.addEventListener('pause', syncIcons);
      video.addEventListener('volumechange', syncIcons);

      // Auto play/pause segun viewport — respeta userPaused.
      // Tambien aplica .is-active al chapter para que el rail pulsa rojo.
      const chapter = card.closest<HTMLElement>('.video-reel__chapter');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              if (!userPaused) video.play().catch(() => {});
              chapter?.classList.add('is-active');
            } else {
              video.pause();
              chapter?.classList.remove('is-active');
            }
          });
        }, { threshold: 0.35 });
        io.observe(video);
      } else {
        video.play().catch(() => {});
      }
    });
  }
</script>
