---
/**
 * MotionDivider — separadores con motivos otomi autenticos del brandbook
 * AMBROSIA, dibujados como SVG inline + CSS animation.
 *
 * Vocabulario visual otomi (tenango):
 *   - Flores cuadripetalas con petalos redondeados (forma de gota)
 *   - Serpentinas/laberintos en curva
 *   - Gotitas/lagrimas dispersas como ornamento
 *   - Puntos pequenos como detalle decorativo
 *   - Simetria compuesta (vertical y horizontal)
 *
 * Paleta brandbook Pantone (acentos sobre blanco, sin fondo morado):
 *   navy #15173d · red #E22319 · cyan #2DBBD8 · pink #DD2396 · yellow #FFC03A · blue #0055B7
 *
 * Variantes:
 *   - ornament  : flor cuadripetala otomi central, rotate slow 18s
 *   - bloom     : banda otomi 3 flores grandes + serpentinas + gotitas, stagger 6s
 *   - drop      : gota de salsa con ornamento otomi alrededor, fall+ripple 3s
 *   - tile      : composicion simetrica 4 esquinas + flor central, pulse 6s
 *   - lightning : rayo otomi, pulse 2s
 *   - transition: linea editorial, draw 1.4s
 */
interface Props {
  variant?: 'ornament' | 'bloom' | 'drop' | 'tile' | 'lightning' | 'transition';
  class?: string;
}

const { variant = 'ornament', class: className = '' } = Astro.props;

// Paleta brandbook
const BRAND = {
  navy:   '#15173d',
  red:    '#E22319',
  cyan:   '#2DBBD8',
  pink:   '#DD2396',
  yellow: '#FFC03A',
  blue:   '#0055B7',
};
---

<div class:list={['motion-divider', `motion-divider--${variant}`, className]} data-motion-divider>
  {variant === 'ornament' && (
    <svg viewBox="-50 -50 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g class="md-ornament">
        {/* Flor cuadripetala otomi: 4 petalos redondeados en cruz */}
        {[0, 90, 180, 270].map((deg, i) => (
          <path
            transform={`rotate(${deg})`}
            d="M 0 -8 C 6 -12 10 -20 6 -28 C 3 -34 -3 -34 -6 -28 C -10 -20 -6 -12 0 -8 Z"
            fill={[BRAND.red, BRAND.yellow, BRAND.cyan, BRAND.pink][i]}
            class="md-ornament__petal"
          />
        ))}
        {/* Circulo central */}
        <circle r="5" fill={BRAND.navy} />
        <circle r="2" fill={BRAND.yellow} />
        {/* 4 gotitas pequenas en diagonal */}
        {[45, 135, 225, 315].map((deg) => (
          <ellipse
            transform={`rotate(${deg}) translate(0 -36)`}
            rx="1.8" ry="3.5"
            fill={BRAND.blue}
            opacity="0.7"
          />
        ))}
        {/* Puntos decorativos exteriores */}
        {[22, 67, 112, 157, 202, 247, 292, 337].map((deg) => (
          <circle
            transform={`rotate(${deg}) translate(0 -42)`}
            r="1"
            fill={BRAND.navy}
            opacity="0.5"
          />
        ))}
      </g>
    </svg>
  )}

  {variant === 'bloom' && (
    <svg viewBox="0 0 720 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g class="md-bloom">
        {/* 3 flores otomi grandes alternantes + serpentinas + gotitas */}
        {[
          { cx: 180, c1: BRAND.red,  c2: BRAND.yellow, c3: BRAND.cyan },
          { cx: 360, c1: BRAND.pink, c2: BRAND.blue,   c3: BRAND.yellow },
          { cx: 540, c1: BRAND.cyan, c2: BRAND.red,    c3: BRAND.pink },
        ].map((m, i) => (
          <g transform={`translate(${m.cx} 40)`} class="md-bloom__motif" style={`--i:${i}`}>
            {/* Flor cuadripetala central */}
            {[0, 90, 180, 270].map((deg, j) => (
              <path
                transform={`rotate(${deg})`}
                d="M 0 -6 C 4 -9 7 -15 5 -20 C 3 -24 -3 -24 -5 -20 C -7 -15 -4 -9 0 -6 Z"
                fill={j % 2 === 0 ? m.c1 : m.c2}
              />
            ))}
            <circle r="3.5" fill={BRAND.navy} />
            <circle r="1.5" fill={m.c3} />
            {/* Gotitas en las 4 diagonales */}
            {[45, 135, 225, 315].map((deg) => (
              <ellipse
                transform={`rotate(${deg}) translate(0 -26)`}
                rx="1.3" ry="2.5"
                fill={m.c3}
                opacity="0.7"
              />
            ))}
          </g>
        ))}

        {/* Serpentinas curvas entre flores */}
        <path
          class="md-bloom__line"
          d="M 60 40 Q 110 20 180 40 T 360 40 T 540 40 T 660 40"
          stroke={BRAND.navy} stroke-width="1" fill="none" opacity="0.35"
        />
        <path
          class="md-bloom__line md-bloom__line--inv"
          d="M 60 40 Q 110 60 180 40 T 360 40 T 540 40 T 660 40"
          stroke={BRAND.navy} stroke-width="0.8" fill="none" opacity="0.25"
          stroke-dasharray="3 4"
        />

        {/* Puntos decorativos dispersos */}
        {[
          [90, 28], [120, 52], [240, 25], [270, 55],
          [420, 28], [450, 55], [600, 25], [630, 55],
        ].map(([cx, cy]) => (
          <circle cx={cx} cy={cy} r="1.4" fill={BRAND.navy} opacity="0.4" />
        ))}

        {/* Pequenas flores secundarias entre las grandes */}
        {[90, 270, 450, 630].map((cx, idx) => (
          <g transform={`translate(${cx} 40)`} opacity="0.6">
            {[0, 72, 144, 216, 288].map((deg) => (
              <circle
                transform={`rotate(${deg}) translate(0 -7)`}
                r="1.6"
                fill={[BRAND.yellow, BRAND.pink, BRAND.cyan, BRAND.red][idx % 4]}
              />
            ))}
            <circle r="1.4" fill={BRAND.navy} />
          </g>
        ))}
      </g>
    </svg>
  )}

  {variant === 'drop' && (
    <svg viewBox="-60 -60 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g class="md-drop">
        {/* Gota grande central — forma organica */}
        <path
          class="md-drop__drop"
          d="M 0 -30 C -12 -15 -18 0 -10 12 C -4 18 4 18 10 12 C 18 0 12 -15 0 -30 Z"
          fill={BRAND.red}
        />
        {/* Pequeno highlight en la gota */}
        <ellipse cx="-3" cy="-15" rx="2" ry="4" fill="#FFFFFF" opacity="0.45" class="md-drop__highlight" />

        {/* 6 gotitas otomi alrededor */}
        {[0, 60, 120, 180, 240, 300].map((deg, i) => (
          <ellipse
            transform={`rotate(${deg}) translate(0 -42)`}
            rx="2" ry="4"
            fill={[BRAND.yellow, BRAND.cyan, BRAND.pink, BRAND.yellow, BRAND.cyan, BRAND.pink][i]}
            class="md-drop__petal"
            style={`--i:${i}`}
          />
        ))}

        {/* Puntos exteriores decorativos */}
        {[30, 90, 150, 210, 270, 330].map((deg) => (
          <circle
            transform={`rotate(${deg}) translate(0 -50)`}
            r="1.2"
            fill={BRAND.navy}
            opacity="0.5"
          />
        ))}
      </g>
    </svg>
  )}

  {variant === 'tile' && (
    <svg viewBox="-100 -100 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g class="md-tile">
        {/* Flor otomi central grande */}
        <g class="md-tile__center">
          {[0, 90, 180, 270].map((deg, i) => (
            <path
              transform={`rotate(${deg})`}
              d="M 0 -10 C 7 -14 12 -22 8 -30 C 4 -36 -4 -36 -8 -30 C -12 -22 -7 -14 0 -10 Z"
              fill={[BRAND.red, BRAND.yellow, BRAND.cyan, BRAND.pink][i]}
            />
          ))}
          <circle r="6" fill={BRAND.navy} />
          <circle r="2.5" fill={BRAND.yellow} />
        </g>

        {/* 4 flores en las esquinas */}
        {[
          { x: -58, y: -58, c: BRAND.cyan },
          { x:  58, y: -58, c: BRAND.pink },
          { x: -58, y:  58, c: BRAND.yellow },
          { x:  58, y:  58, c: BRAND.blue },
        ].map((corner, i) => (
          <g transform={`translate(${corner.x} ${corner.y})`} class="md-tile__corner" style={`--i:${i}`}>
            {[0, 90, 180, 270].map((deg) => (
              <ellipse
                transform={`rotate(${deg})`}
                cx="0" cy="-7"
                rx="3" ry="6"
                fill={corner.c}
              />
            ))}
            <circle r="2.5" fill={BRAND.navy} />
          </g>
        ))}

        {/* Serpentinas en las 4 medias-lineas */}
        {[
          'M -58 -58 Q -30 -50 0 -40',
          'M  58 -58 Q  30 -50 0 -40',
          'M -58  58 Q -30  50 0  40',
          'M  58  58 Q  30  50 0  40',
        ].map((d) => (
          <path d={d} stroke={BRAND.navy} stroke-width="0.8" fill="none" opacity="0.4" stroke-dasharray="3 3" />
        ))}

        {/* Gotitas otomi en las 4 medias */}
        {[
          { x:   0, y: -75, deg:   0 },
          { x:  75, y:   0, deg:  90 },
          { x:   0, y:  75, deg: 180 },
          { x: -75, y:   0, deg: 270 },
        ].map((g) => (
          <ellipse
            transform={`translate(${g.x} ${g.y}) rotate(${g.deg})`}
            rx="2" ry="5"
            fill={BRAND.red}
            opacity="0.7"
          />
        ))}

        {/* Puntos decorativos dispersos */}
        {[
          [-28, -28], [28, -28], [-28, 28], [28, 28],
          [-78, 0], [78, 0], [0, -78], [0, 78],
        ].map(([cx, cy]) => (
          <circle cx={cx} cy={cy} r="1.2" fill={BRAND.navy} opacity="0.4" />
        ))}
      </g>
    </svg>
  )}

  {variant === 'lightning' && (
    <svg viewBox="-40 -40 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g class="md-lightning">
        {/* Rayo otomi estilizado */}
        <path d="M 5 -32 L -15 0 L -3 0 L -10 30 L 15 -5 L 3 -5 Z" fill={BRAND.red} />
        {/* Puntos a los lados */}
        {[
          [-25, -15], [25, -15], [-25, 15], [25, 15],
        ].map(([cx, cy]) => (
          <circle cx={cx} cy={cy} r="1.5" fill={BRAND.yellow} opacity="0.7" />
        ))}
      </g>
    </svg>
  )}

  {variant === 'transition' && (
    <svg viewBox="0 0 600 12" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g class="md-transition-g">
        <line x1="0" y1="6" x2="600" y2="6" stroke={BRAND.navy} stroke-width="1" class="md-transition" />
        {/* Mini-flor central como pivote */}
        <g transform="translate(300 6)">
          {[0, 90, 180, 270].map((deg, i) => (
            <circle
              transform={`rotate(${deg}) translate(0 -3)`}
              r="1.5"
              fill={[BRAND.red, BRAND.yellow, BRAND.cyan, BRAND.pink][i]}
            />
          ))}
          <circle r="1.5" fill={BRAND.navy} />
        </g>
      </g>
    </svg>
  )}
</div>

<style>
  .motion-divider {
    display: block;
    margin: 0 auto;
    pointer-events: none;
    line-height: 0;
  }
  .motion-divider svg {
    width: 100%;
    height: 100%;
    display: block;
    background: transparent;
    overflow: visible;
  }

  /* Tamanos editoriales sutiles */
  .motion-divider--ornament {
    width: clamp(72px, 8vw, 104px);
    aspect-ratio: 1 / 1;
    padding: 1.25rem 0;
  }
  .motion-divider--bloom {
    width: 100%;
    max-width: 720px;
    aspect-ratio: 720 / 80;
    padding: 1rem 0;
  }
  .motion-divider--drop {
    width: clamp(72px, 8vw, 104px);
    aspect-ratio: 1 / 1;
    padding: 1.25rem 0;
  }
  .motion-divider--tile {
    width: clamp(120px, 14vw, 170px);
    aspect-ratio: 1 / 1;
    padding: 1.5rem 0;
  }
  .motion-divider--lightning {
    width: clamp(48px, 6vw, 70px);
    aspect-ratio: 1 / 1;
    padding: 0.65rem 0;
  }
  .motion-divider--transition {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 600 / 12;
    padding: 0.65rem 0;
  }

  /* ─── Animaciones CSS por variante ─── */

  /* Ornament: rotacion muy lenta de la flor entera */
  .md-ornament {
    transform-origin: center;
    animation: md-rotate 18s linear infinite;
  }
  .md-ornament__petal {
    transform-origin: center;
    animation: md-pulse-soft 4s ease-in-out infinite;
  }
  .md-ornament__petal:nth-child(2) { animation-delay: 0.3s; }
  .md-ornament__petal:nth-child(3) { animation-delay: 0.6s; }
  .md-ornament__petal:nth-child(4) { animation-delay: 0.9s; }

  /* Bloom: cada flor entra con stagger y respira; serpentinas oscilan */
  .md-bloom__motif {
    transform-origin: center;
    animation: md-bloom-breathe 6s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.4s);
  }
  .md-bloom__line {
    stroke-dasharray: 800;
    stroke-dashoffset: 800;
    animation: md-draw-line 3s ease-out 0.4s forwards;
  }
  .md-bloom__line--inv {
    animation-delay: 0.7s;
  }

  /* Drop: gota cae + ondas; petalos pulsan */
  .md-drop__drop {
    transform-origin: center;
    animation: md-drop-pulse 3s ease-in-out infinite;
  }
  .md-drop__highlight {
    animation: md-fade-pulse 3s ease-in-out infinite;
  }
  .md-drop__petal {
    transform-origin: center;
    animation: md-fade-pulse 3s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.15s);
  }

  /* Tile: flor central respira; esquinas pulsan en stagger */
  .md-tile__center {
    transform-origin: center;
    animation: md-pulse-soft 5s ease-in-out infinite;
  }
  .md-tile__corner {
    transform-origin: center;
    animation: md-corner-pulse 6s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.25s);
  }

  /* Lightning: pulso */
  .md-lightning {
    transform-origin: center;
    animation: md-pulse-soft 2s ease-in-out infinite;
  }

  /* Transition: linea se dibuja una vez */
  .md-transition {
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: md-draw-line 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes md-rotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes md-pulse-soft {
    0%, 100% { transform: scale(1);    opacity: 1; }
    50%      { transform: scale(1.06); opacity: 0.92; }
  }
  @keyframes md-bloom-breathe {
    0%, 100% { transform: scale(0.95); opacity: 0.85; }
    50%      { transform: scale(1.05); opacity: 1; }
  }
  @keyframes md-drop-pulse {
    0%, 100% { transform: translateY(0) scale(1); }
    40%      { transform: translateY(-4px) scale(1.02); }
    60%      { transform: translateY(2px) scale(0.98); }
  }
  @keyframes md-fade-pulse {
    0%, 100% { opacity: 0.5; }
    50%      { opacity: 1; }
  }
  @keyframes md-corner-pulse {
    0%, 100% { transform: scale(0.92); opacity: 0.7; }
    50%      { transform: scale(1.05); opacity: 1; }
  }
  @keyframes md-draw-line {
    to { stroke-dashoffset: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .md-ornament,
    .md-ornament__petal,
    .md-bloom__motif,
    .md-bloom__line,
    .md-drop__drop,
    .md-drop__highlight,
    .md-drop__petal,
    .md-tile__center,
    .md-tile__corner,
    .md-lightning,
    .md-transition {
      animation: none !important;
      stroke-dashoffset: 0 !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
