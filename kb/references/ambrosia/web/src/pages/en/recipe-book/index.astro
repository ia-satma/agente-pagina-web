---
export const prerender = true;
/**
 * /en/recipe-book — Recipe Book index (Chapter III, World 03).
 * Each card links to the ES detail page (recipes are not yet translated;
 * the EN index marks each card with "Recipe in Spanish").
 */
import Base from '~/layouts/Base.astro';
import PageHero from '~/components/PageHero.astro';
import RecipeIndex from '~/components/RecipeIndex.astro';
import Footer from '~/components/Footer.astro';
import { t } from '~/i18n';

const locale = 'en' as const;
const dict = t(locale);
const page = (dict as any).pages.recetario;
---

<Base title={`AMBROSIA — ${page.eyebrow}`} locale={locale}>
  <PageHero
    eyebrow={page.eyebrow}
    title={page.title}
    body={page.body}
    accent="pink"
    sealVariant="magenta"
    locale={locale}
    videoBg={{ webm: '/video/reel-02.webm', mp4: '/video/reel-02.mp4' }}
    videoOverlayOpacity={0.66}
  />

  <RecipeIndex locale={locale} esOnly />

  <Footer locale={locale} />
</Base>
