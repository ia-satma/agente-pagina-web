---
export const prerender = true;
/**
 * /mesas — Mesas Selectas (Capitulo IV, Mundo 04).
 * Introduce el mundo y bifurca en 2 caminos: restaurantes / boutique.
 */
import Base from '~/layouts/Base.astro';
import PageHero from '~/components/PageHero.astro';
import TablesSplit from '~/components/TablesSplit.astro';
import Footer from '~/components/Footer.astro';
import SEOSchema from '~/components/SEOSchema.astro';
import { t } from '~/i18n';
import { isVisible } from '~/lib/settings';

const locale = 'es' as const;
const dict = t(locale);
const page = (dict as any).pages.mesas;
---

<Base title={`AMBROSIA — ${page.eyebrow}`} locale={locale}>
  <SEOSchema type="restaurant-list" locale={locale} />
  <PageHero
    eyebrow={page.eyebrow}
    title={page.title}
    body={page.body}
    accent="red"
    sealVariant="magenta"
    locale={locale}
    videoBg={{ webm: '/video/reel-03.webm', mp4: '/video/reel-03.mp4' }}
    videoOverlayOpacity={0.66}
  />

  {isVisible('mesas.tablesSplit') && <TablesSplit locale={locale} />}

  <Footer locale={locale} />
</Base>
