---
export const prerender = true;
/**
 * /origen — El Origen (Capitulo I, Mundo 01).
 *
 * Reune todo el storytelling del mito que vivia disperso entre la home,
 * /historia, /producto. Estructura editorial:
 *   PageHero → Diptych mito → Interlude → Diptych origen → Ritual → TimelineCultural
 */
import Base from '~/layouts/Base.astro';
import Hero from '~/components/Hero.astro';
import PageHero from '~/components/PageHero.astro';
import Diptych from '~/components/Diptych.astro';
import Interlude from '~/components/Interlude.astro';
import Ritual from '~/components/Ritual.astro';
import TimelineCultural from '~/components/TimelineCultural.astro';
import Footer from '~/components/Footer.astro';
import SEOSchema from '~/components/SEOSchema.astro';
import { t } from '~/i18n';
import { isVisible } from '~/lib/settings';

const locale = 'es' as const;
const dict = t(locale);
const page = (dict as any).pages.origen;
---

<Base
  title={`AMBROSIA — ${page.eyebrow}`}
  locale={locale}
  description="El origen mítico de Salsa AMBROSIA: del nectar de los dioses del Olimpo al molcajete mexica, una salsa picante embotellada a mano en Monterrey."
  ogImage="/images/brand/mito-tezcatlipoca.webp"
>
  {/* Back link removido (era duplicado del que ya trae PageHero) */}
  <SEOSchema type="origen" locale={locale} />

  {/* Hero original con scroll-driven pin (god-mexica + god-greco + bottle handover) */}
  {isVisible('origen.hero') && <Hero locale={locale} />}

  <PageHero
    eyebrow={page.eyebrow}
    title={page.title}
    body={page.body}
    accent="purple"
    sealVariant="purple"
    showPhonetic
    locale={locale}
  />

  {isVisible('origen.diptychMito') && (
    <Diptych
      id="mito"
      eyebrow={dict.mito.eyebrow}
      title={dict.mito.title}
      body={dict.mito.body}
      image="/images/brand/mito-tezcatlipoca.webp"
      imageAlt="Pintura barroca novohispana de Tezcatlipoca descendiendo del cielo nocturno con la botella de Salsa AMBROSIA"
      align="left"
      bg="white"
      priority
    />
  )}

  {isVisible('origen.interlude') && <Interlude locale={locale} />}

  {isVisible('origen.diptychOrigen') && (
    <Diptych
      id="origen-mexica"
      eyebrow={dict.origen.eyebrow}
      title={dict.origen.title}
      body={dict.origen.body}
      image="/images/brand/origen-molcajete.webp"
      imageAlt="Naturaleza muerta barroca novohispana: molcajete de basalto volcanico con chile rojo recien molido y la botella de Salsa AMBROSIA como linaje mexica embotellado"
      align="right"
      bg="white"
    />
  )}

  {isVisible('origen.ritual') && <Ritual locale={locale} />}

  {/* Linea del tiempo cultural: del mito a AMBROSIA hoy */}
  {isVisible('origen.timeline') && <TimelineCultural locale={locale} />}

  <Footer locale={locale} />
</Base>

<style>
  /* Back link flotante — top-left, sobre el Hero, navy editorial */
  .origen-back {
    position: fixed;
    top: clamp(5rem, 9vh, 6.5rem);
    left: clamp(1rem, 2.5vw, 2rem);
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem 0.55rem 0.75rem;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #FFFFFF;
    background: color-mix(in srgb, var(--navy) 78%, transparent);
    border: 1px solid color-mix(in srgb, #FFFFFF 18%, transparent);
    border-radius: 999px;
    text-decoration: none;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 8px 24px -12px rgba(0, 0, 0, 0.4);
    transition:
      background-color var(--dur-medium) var(--ease-medium),
      border-color var(--dur-medium) var(--ease-medium),
      transform var(--dur-medium) var(--ease-medium),
      gap var(--dur-medium) var(--ease-medium);
  }
  .origen-back:hover {
    background: var(--red);
    border-color: var(--red);
    transform: translateX(-2px);
    gap: 0.75rem;
  }
  .origen-back svg {
    transition: transform var(--dur-medium) var(--ease-medium);
  }
  .origen-back:hover svg {
    transform: translateX(-3px);
  }
  @media (max-width: 600px) {
    .origen-back {
      top: 4.5rem;
      left: 1rem;
      padding: 0.45rem 0.85rem 0.45rem 0.65rem;
      font-size: 0.6rem;
    }
  }
</style>
