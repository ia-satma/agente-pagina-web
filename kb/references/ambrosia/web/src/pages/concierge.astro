---
export const prerender = true;
/**
 * /concierge — Concierge (Capitulo V, Mundo 05).
 * Reemplaza /contacto con segmentacion por intent (HORECA / prensa / regalo).
 */
import Base from '~/layouts/Base.astro';
import PageHero from '~/components/PageHero.astro';
import ConciergeIntent from '~/components/ConciergeIntent.astro';
import ConciergeForm from '~/components/ConciergeForm.astro';
import CommunityCTA from '~/components/CommunityCTA.astro';
import Footer from '~/components/Footer.astro';
import SEOSchema from '~/components/SEOSchema.astro';
import { t } from '~/i18n';
import { isVisible } from '~/lib/settings';

const locale = 'es' as const;
const dict = t(locale);
const page = (dict as any).pages.concierge;
---

<Base title={`AMBROSIA — ${page.eyebrow}`} locale={locale} description="Concierge AMBROSIA — HORECA, prensa, regalo corporativo. Contacto directo para distribucion privada y experiencias selectas.">
  <SEOSchema type="concierge" locale={locale} />
  <PageHero
    eyebrow={page.eyebrow}
    title={page.title}
    body={page.body}
    accent="yellow"
    sealVariant="silver"
    locale={locale}
    videoBg={{ webm: '/video/hero-bottle-frame.webm', mp4: '/video/hero-bottle-frame.mp4' }}
    videoOverlayOpacity={0.66}
  />

  {isVisible('concierge.intent') && <ConciergeIntent locale={locale} />}

  {isVisible('concierge.form') && <ConciergeForm locale={locale} />}

  <CommunityCTA locale={locale} />

  <Footer locale={locale} />
</Base>
