---
/**
 * AdminLayout — Shell editorial del backend AMBROSIA.
 *
 * Sidebar con secciones según rol:
 *  - admin   ve todo
 *  - editor  ve Contenido + Media + parte de Settings
 *  - viewer  solo Dashboard + Contenido (read)
 *
 * Branding: navy + red Pantone 485 + Optimus serif para títulos.
 */
import type { User, Role } from '~/lib/users';
import { can } from '~/lib/users';

interface Props {
  title: string;
  user: User;
  active?: 'dashboard' | 'content' | 'pages' | 'users' | 'media' | 'settings' | 'audit';
  /** Si true, el área de contenido pierde padding y permite que children ocupen toda la altura (para iframes/canvas) */
  fullBleed?: boolean;
}

const { title, user, active = 'dashboard', fullBleed = false } = Astro.props;
const role = user.role as Role;

interface NavItem {
  key: NonNullable<Props['active']>;
  label: string;
  href: string;
  icon: string;
  permission: string;
}

const navItems: NavItem[] = [
  { key: 'dashboard', label: 'Inicio',        href: '/admin/',              icon: 'M3 12L12 4l9 8M5 10v10h14V10', permission: 'content.read' },
  { key: 'content',   label: 'Contenido',     href: '/admin/contenido',     icon: 'M4 4h16v4H4zM4 12h16v4H4zM4 20h10v0H4z', permission: 'content.read' },
  { key: 'pages',     label: 'Páginas',       href: '/admin/paginas',       icon: 'M9 4h6l4 4v12a2 2 0 01-2 2H7a2 2 0 01-2-2V6a2 2 0 012-2h2zM9 13h6m-6 4h6m-6-8h2', permission: 'pages.read' },
  { key: 'media',     label: 'Medios',        href: '/admin/media',         icon: 'M21 8v10a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2h7l2 4h5a2 2 0 012 2z', permission: 'media.read' },
  { key: 'settings',  label: 'Configuración', href: '/admin/configuracion', icon: 'M12 8a4 4 0 100 8 4 4 0 000-8zm9 4l-2-1 1-2-2-2-2 1-1-2h-2l-1 2-2-1-2 2 1 2-2 1v2l2 1-1 2 2 2 2-1 1 2h2l1-2 2 1 2-2-1-2 2-1z', permission: 'settings.read' },
  { key: 'users',     label: 'Usuarios',      href: '/admin/usuarios',      icon: 'M16 12a4 4 0 10-8 0 4 4 0 008 0zM3 22c0-3.314 4.03-6 9-6s9 2.686 9 6', permission: 'users.read' },
  { key: 'audit',     label: 'Actividad',     href: '/admin/actividad',     icon: 'M12 8v4l3 2m6-2a9 9 0 11-18 0 9 9 0 0118 0z', permission: 'audit.read' },
];

const visibleItems = navItems.filter((item) => can(role, item.permission));
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>AMBROSIA · {title}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preload" href="/fonts/OptimusPrinceps.ttf" as="font" type="font/ttf" crossorigin />
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <a class="sidebar__brand" href="/admin/">
        <span class="sidebar__mark">Ambros<em>í</em>a</span>
        <span class="sidebar__sub">Backend editorial</span>
      </a>

      <nav class="sidebar__nav" aria-label="Backend">
        {visibleItems.map((item) => (
          <a
            href={item.href}
            class:list={['sidebar__item', active === item.key && 'is-active']}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={item.icon} />
            </svg>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

      <div class="sidebar__foot">
        <a class="sidebar__site" href="/" target="_blank" rel="noopener">
          <span>Ver sitio</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M14 4h6v6M10 14L20 4M19 14v5a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </aside>

    <div class="main">
      <header class="topbar">
        <div class="topbar__title">
          <h1>{title}</h1>
        </div>
        <div class="topbar__user">
          <div class="topbar__userInfo">
            <span class="topbar__userName">{user.name ?? user.email}</span>
            <span class="topbar__userRole">{role}</span>
          </div>
          <a class="topbar__logout" href="/api/auth/logout">Salir</a>
        </div>
      </header>

      <main class:list={['content', fullBleed && 'content--full']}>
        <slot />
      </main>
    </div>
  </div>

  <style is:global>
    :root {
      --bg:    #EEF1F8;
      --card:  #FFFFFF;
      --navy:  #15173d;
      --red:   #E22319;
      --cream: #F6F1E6;
      --line:  rgba(21, 23, 61, 0.12);
      --line-strong: rgba(21, 23, 61, 0.24);
      --text:  #15173d;
      --text-muted: rgba(21, 23, 61, 0.62);
      --radius: 6px;
      --space: 1rem;
    }
    @font-face {
      font-family: 'Optimus Princeps';
      src: url('/fonts/OptimusPrinceps.ttf') format('truetype');
      font-display: swap;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 14px;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--navy); }

    .layout {
      display: grid;
      grid-template-columns: 240px 1fr;
      min-height: 100vh;
    }

    /* ─── Sidebar ─── */
    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      background: var(--navy);
      color: var(--cream);
      display: flex;
      flex-direction: column;
      padding: 1.25rem 0;
      border-right: 1px solid var(--line-strong);
    }
    .sidebar__brand {
      padding: 0 1.5rem 1.5rem;
      text-decoration: none;
      color: var(--cream);
      border-bottom: 1px solid rgba(246, 241, 230, 0.12);
      display: block;
    }
    .sidebar__mark {
      display: block;
      font-family: 'Optimus Princeps', 'Times New Roman', serif;
      font-size: 1.5rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cream);
    }
    .sidebar__mark em { color: var(--red); font-style: italic; }
    .sidebar__sub {
      display: block;
      margin-top: 0.4rem;
      font-size: 0.62rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      opacity: 0.55;
    }

    .sidebar__nav {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: 1rem 0;
    }
    .sidebar__item {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.75rem 1.5rem;
      color: var(--cream);
      text-decoration: none;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      opacity: 0.72;
      border-left: 2px solid transparent;
      transition: background 200ms, opacity 200ms, border-color 200ms;
    }
    .sidebar__item:hover {
      opacity: 1;
      background: rgba(246, 241, 230, 0.05);
    }
    .sidebar__item.is-active {
      opacity: 1;
      background: rgba(226, 35, 25, 0.10);
      border-left-color: var(--red);
    }

    .sidebar__foot {
      padding: 1rem 1.5rem;
      border-top: 1px solid rgba(246, 241, 230, 0.12);
    }
    .sidebar__site {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.7rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--cream);
      opacity: 0.65;
      text-decoration: none;
    }
    .sidebar__site:hover { opacity: 1; color: var(--red); }

    /* ─── Main ─── */
    .main {
      display: flex;
      flex-direction: column;
      min-width: 0;
      height: 100vh; /* permite que .content fluya correctamente para iframes/full-bleed */
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 2rem;
      background: var(--card);
      border-bottom: 1px solid var(--line);
    }
    .topbar__title h1 {
      margin: 0;
      font-family: 'Optimus Princeps', serif;
      font-weight: 400;
      font-size: 1.35rem;
      letter-spacing: 0.05em;
      color: var(--navy);
    }
    .topbar__user {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .topbar__userInfo {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      line-height: 1.3;
    }
    .topbar__userName { font-weight: 600; font-size: 0.85rem; }
    .topbar__userRole {
      font-size: 0.6rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--red);
      opacity: 0.85;
    }
    .topbar__logout {
      padding: 0.55rem 1rem;
      font-size: 0.65rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--navy);
      background: transparent;
      border: 1px solid var(--line-strong);
      border-radius: 999px;
      text-decoration: none;
      transition: background 200ms, color 200ms, border-color 200ms;
    }
    .topbar__logout:hover {
      background: var(--red);
      border-color: var(--red);
      color: #FFFFFF;
    }

    .content {
      flex: 1 1 0;
      padding: 2rem;
      overflow-y: auto;
      min-height: 0; /* indispensable para que el flex hijo pueda calcular altura real */
    }
    /* Variante sin padding para iframes y vistas tipo canvas/edge-to-edge */
    .content.content--full {
      padding: 0;
      overflow: hidden;
    }

    /* ─── Cards reutilizables ─── */
    .panel {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1.5rem;
    }
    .panel + .panel { margin-top: 1.5rem; }
    .panel__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.25rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--line);
    }
    .panel__title {
      margin: 0;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--navy);
    }
    .panel__hint {
      margin: 0 0 1rem;
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.55;
    }

    /* ─── Buttons ─── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.65rem 1.1rem;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--cream);
      background: var(--navy);
      border: 1px solid var(--navy);
      border-radius: 4px;
      cursor: pointer;
      text-decoration: none;
      transition: background 200ms, border-color 200ms, transform 200ms;
    }
    .btn:hover { background: var(--red); border-color: var(--red); transform: translateY(-1px); }
    .btn--ghost {
      color: var(--navy);
      background: transparent;
    }
    .btn--ghost:hover { color: #FFFFFF; background: var(--navy); }
    .btn--danger { background: var(--red); border-color: var(--red); }
    .btn--danger:hover { background: #B91A12; border-color: #B91A12; transform: none; }

    /* ─── Inputs ─── */
    .input, .select, .textarea {
      width: 100%;
      padding: 0.75rem 0.9rem;
      font: inherit;
      font-size: 0.9rem;
      color: var(--navy);
      background: var(--card);
      border: 1px solid var(--line-strong);
      border-radius: 4px;
      transition: border-color 200ms, box-shadow 200ms;
    }
    .input:focus, .select:focus, .textarea:focus {
      outline: none;
      border-color: var(--navy);
      box-shadow: 0 0 0 3px rgba(226, 35, 25, 0.14);
    }
    .label {
      display: block;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 0.35rem;
    }
    .field { margin-bottom: 1rem; }

    /* ─── Tables ─── */
    .table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.88rem;
    }
    .table th, .table td {
      padding: 0.8rem 0.75rem;
      text-align: left;
      border-bottom: 1px solid var(--line);
    }
    .table th {
      font-size: 0.62rem;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--text-muted);
      font-weight: 700;
    }
    .table tbody tr:hover { background: rgba(21, 23, 61, 0.025); }

    /* ─── Pills (role badges) ─── */
    .pill {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      border-radius: 999px;
    }
    .pill--admin  { color: var(--red); background: rgba(226, 35, 25, 0.10); }
    .pill--editor { color: var(--navy); background: rgba(21, 23, 61, 0.10); }
    .pill--viewer { color: var(--text-muted); background: rgba(21, 23, 61, 0.06); }
    .pill--active { color: #1a7f3c; background: rgba(26, 127, 60, 0.10); }
    .pill--inactive { color: var(--text-muted); background: rgba(21, 23, 61, 0.06); }

    /* ─── Flash messages ─── */
    .flash {
      padding: 0.9rem 1.1rem;
      margin-bottom: 1.25rem;
      font-size: 0.85rem;
      border-radius: 4px;
    }
    .flash--success { background: rgba(26, 127, 60, 0.08); color: #1a7f3c; border: 1px solid rgba(26, 127, 60, 0.22); }
    .flash--error   { background: rgba(226, 35, 25, 0.08); color: var(--red); border: 1px solid rgba(226, 35, 25, 0.22); }

    /* ─── Responsive ─── */
    @media (max-width: 720px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: static; height: auto; }
      .sidebar__nav { flex-direction: row; overflow-x: auto; padding: 0.5rem; }
      .sidebar__item { flex-direction: column; padding: 0.5rem 1rem; font-size: 0.65rem; }
      .sidebar__item.is-active { border-left: none; border-bottom: 2px solid var(--red); }
      .topbar { padding: 1rem; }
      .content { padding: 1rem; }
      .main { height: auto; min-height: 0; }
    }
  </style>
</body>
</html>
